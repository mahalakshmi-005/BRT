@model Category
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Category";
}
<h3 class="mb-4">Edit Category</h3>
<div class="admin-card" style="max-width:500px">
    <form asp-action="EditCategory" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label">Name (English)</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Name (Tamil)</label>
            <input asp-for="NameTamil" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Type</label>
            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<CategoryType>()"></select>
        </div>
        <div class="mb-3">
            <label class="form-label">Display Order</label>
            <input asp-for="DisplayOrder" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label class="form-label">Category Image</label>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-2"><img src="@Model.ImageUrl" style="max-width:100px;border-radius:8px" /></div>
            }
            <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.gif" />
            <input asp-for="ImageUrl" class="form-control mt-2" placeholder="or paste an image URL" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label class="form-check-label">Active</label>
        </div>
        <button class="btn btn-brt">Update</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
