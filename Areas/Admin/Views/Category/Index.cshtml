@model List<Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Categories</h3>
    <a asp-action="CreateCategory" class="btn btn-brt">+ Add Category</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@foreach (var cat in Model)
{
    <div class="admin-card mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@cat.Name <span class="badge bg-secondary">@cat.Type</span> @if (!cat.IsActive) { <span class="badge bg-danger">Inactive</span> }</h5>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="CreateSubCategory" asp-route-categoryId="@cat.Id" class="btn btn-sm btn-outline-secondary">+ Sub-category</a>
                <a asp-action="EditCategory" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Remove this category?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </div>
        </div>
        @if (cat.SubCategories.Any())
        {
            <table class="table table-sm mt-3 mb-0">
                <tbody>
                @foreach (var sub in cat.SubCategories.OrderBy(s => s.DisplayOrder))
                {
                    <tr>
                        <td>@sub.Name @if (!sub.IsActive) { <span class="badge bg-danger">Inactive</span> }</td>
                        <td class="text-end">
                            <a asp-action="EditSubCategory" asp-route-id="@sub.Id" class="btn btn-sm btn-link">Edit</a>
                            <form asp-action="DeleteSubCategory" asp-route-id="@sub.Id" method="post" class="d-inline" onsubmit="return confirm('Remove this sub-category?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-link text-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
}
