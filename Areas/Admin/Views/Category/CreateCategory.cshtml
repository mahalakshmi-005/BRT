@model Category
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Category";
}

<style>
    :root {
        --brt-navy-dark: #0B132A;
        --brt-gold-accent: #D97706;
        --brt-gold-hover: #B45309;
        --brt-border-color: #E2E8F0;
        --brt-text-dark: #0F172A;
        --brt-text-muted: #64748B;
    }

    /* Header Section */
    .page-header-container {
        margin-bottom: 2rem;
    }

    .eyebrow-text {
        color: var(--brt-gold-accent);
        font-size: 0.725rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.2rem;
    }

    .page-title {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0;
    }

    /* Card Container */
    .form-card-container {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        padding: 2rem;
        max-width: 580px;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
    }

    /* Input Styles */
    .form-label-custom {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--brt-text-dark);
        margin-bottom: 0.4rem;
    }

    .form-control-custom, .form-select-custom {
        height: 44px;
        border-radius: 10px;
        border: 1px solid var(--brt-border-color);
        font-size: 0.875rem;
        color: var(--brt-text-dark);
        background-color: #FAFAFA;
        padding: 0.6rem 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control-custom:focus, .form-select-custom:focus {
        background-color: #FFFFFF;
        border-color: var(--brt-gold-accent);
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
    }

    /* Image Box Dropzone Style */
    .image-preview-wrapper {
        border: 2px dashed var(--brt-border-color);
        border-radius: 12px;
        padding: 1.25rem;
        background: #FAFAFA;
        text-align: center;
        transition: border-color 0.2s ease;
    }

    .image-preview-wrapper:hover {
        border-color: var(--brt-gold-accent);
    }

    .preview-box {
        width: 70px;
        height: 70px;
        border-radius: 10px;
        object-fit: cover;
        display: none;
        margin: 0 auto 0.75rem auto;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    /* Custom Switch Accent */
    .form-switch .form-check-input:checked {
        background-color: var(--brt-gold-accent);
        border-color: var(--brt-gold-accent);
    }

    /* Action Buttons */
    .btn-brt-gold {
        background: var(--brt-gold-accent);
        color: #FFFFFF;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        height: 44px;
        border-radius: 22px;
        border: none;
        padding: 0 1.5rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);
    }

    .btn-brt-gold:hover {
        background: var(--brt-gold-hover);
        color: #FFFFFF;
        box-shadow: 0 6px 16px rgba(217, 119, 6, 0.3);
        transform: translateY(-1px);
    }

    .btn-cancel-custom {
        height: 44px;
        border-radius: 22px;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0 1.25rem;
        display: inline-flex;
        align-items: center;
    }
</style>

<!-- Header Section -->
<div class="page-header-container">
    <span class="eyebrow-text">INVENTORY MANAGEMENT</span>
    <h3 class="page-title">Add Category</h3>
</div>

<!-- Main Form Card -->
<div class="form-card-container">
    <form asp-action="CreateCategory" method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()

        <!-- Validation Summary Alert -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 rounded-3 py-2 small mb-3">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-0"></div>
            </div>
        }

        <!-- Name Inputs Row -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label-custom">Name (English)</label>
                <input asp-for="Name" class="form-control form-control-custom" placeholder="e.g. Garlic" />
                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label-custom">Name (Tamil)</label>
                <input asp-for="NameTamil" class="form-control form-control-custom" placeholder="e.g. பூண்டு" />
                <span asp-validation-for="NameTamil" class="text-danger small mt-1 d-block"></span>
            </div>
        </div>

        <!-- Type & Display Order Row -->
        <div class="row g-3 mb-3">
            <div class="col-md-7">
                <label class="form-label-custom">Type</label>
                <select asp-for="Type" class="form-select form-select-custom" asp-items="Html.GetEnumSelectList<CategoryType>()"></select>
                <span asp-validation-for="Type" class="text-danger small mt-1 d-block"></span>
            </div>
            <div class="col-md-5">
                <label class="form-label-custom">Display Order</label>
                <input asp-for="DisplayOrder" class="form-control form-control-custom" type="number" placeholder="1" />
                <span asp-validation-for="DisplayOrder" class="text-danger small mt-1 d-block"></span>
            </div>
        </div>

        <!-- Category Image Section -->
        <div class="mb-4">
            <label class="form-label-custom">Category Image</label>
            <div class="image-preview-wrapper">
                <img id="imagePreview" src="#" alt="Preview" class="preview-box" />
                
                <input type="file" id="imageFileInput" name="imageFile" class="form-control form-control-custom mb-2" accept=".jpg,.jpeg,.png,.webp,.gif" onchange="previewSelectedImage(this)" />
                
                <div class="text-muted small my-1">— OR —</div>
                
                <input asp-for="ImageUrl" class="form-control form-control-custom" placeholder="Paste image URL (e.g. https://...)" />
            </div>
            <span asp-validation-for="ImageUrl" class="text-danger small mt-1 d-block"></span>
        </div>

        <!-- Active Toggle Switch -->
        <div class="form-check form-switch mb-4 ps-5">
            <input asp-for="IsActive" class="form-check-input fs-5" style="margin-left: -2.5rem;" checked />
            <label class="form-check-label fw-semibold text-dark fs-6" style="margin-top: 2px;">Active Status</label>
        </div>

        <!-- Action Buttons -->
        <div class="d-flex align-items-center gap-2 pt-2">
            <button type="submit" class="btn btn-brt-gold d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">save</span>
                <span>Save Category</span>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-cancel-custom">Cancel</a>
        </div>
    </form>
</div>

<!-- Image Preview Script -->
<script>
    function previewSelectedImage(input) {
        const preview = document.getElementById('imagePreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
            }
            reader.readAsDataURL(input.files[0]);
        } else {
            preview.style.display = 'none';
        }
    }
</script>
