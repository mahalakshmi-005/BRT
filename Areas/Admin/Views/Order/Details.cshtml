@model OrderRequest
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Order Details - " + Model.OrderNumber;
}

<style>
    :root {
        --brt-navy-dark: #0B132A;
        --brt-gold-accent: #D97706;
        --brt-gold-hover: #B45309;
        --brt-border-color: #E2E8F0;
        --brt-text-dark: #0F172A;
        --brt-text-muted: #64748B;
    }

    /* Header Section */
    .page-header-container {
        margin-bottom: 2rem;
    }

    .eyebrow-text {
        color: var(--brt-gold-accent);
        font-size: 0.725rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.2rem;
    }

    .page-title {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0;
    }

    /* Cards */
    .details-card {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.02);
    }

    .card-title-custom {
        font-family: Georgia, serif;
        font-weight: 700;
        color: var(--brt-navy-dark);
        font-size: 1.15rem;
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #F1F5F9;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Quick Action Buttons */
    .btn-action-call {
        background: #F1F5F9;
        color: var(--brt-navy-dark);
        font-size: 0.825rem;
        font-weight: 600;
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        transition: all 0.2s ease;
    }

    .btn-action-call:hover {
        background: #E2E8F0;
        color: var(--brt-navy-dark);
    }

    .btn-action-whatsapp {
        background: #DCFCE7;
        color: #15803D;
        font-size: 0.825rem;
        font-weight: 600;
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        transition: all 0.2s ease;
    }

    .btn-action-whatsapp:hover {
        background: #BBF7D0;
        color: #166534;
    }

    /* Table Styling */
    .table-invoice {
        margin-bottom: 0;
    }

    .table-invoice th {
        background: #F8FAFC;
        color: var(--brt-text-muted);
        font-size: 0.725rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid var(--brt-border-color);
        padding: 0.75rem 0.75rem;
    }

    .table-invoice td {
        padding: 0.85rem 0.75rem;
        vertical-align: middle;
        font-size: 0.875rem;
        color: var(--brt-text-dark);
        border-bottom: 1px solid #F1F5F9;
    }

    .total-banner {
        background: #FFFBEB;
        border: 1px dashed #FDE68A;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }

    /* Timeline Styling */
    .timeline {
        position: relative;
        padding-left: 1.5rem;
        list-style: none;
        margin-bottom: 0;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 6px;
        top: 5px;
        bottom: 5px;
        width: 2px;
        background: var(--brt-border-color);
    }

    .timeline-item {
        position: relative;
        margin-bottom: 1.25rem;
    }

    .timeline-item:last-child {
        margin-bottom: 0;
    }

    .timeline-point {
        position: absolute;
        left: -1.5rem;
        top: 3px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--brt-gold-accent);
        border: 3px solid #FFFFFF;
        box-shadow: 0 0 0 2px var(--brt-gold-accent);
    }

    /* Form Controls */
    .form-label-custom {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--brt-text-dark);
        margin-bottom: 0.35rem;
    }

    .form-control-custom, .form-select-custom {
        border-radius: 10px;
        border: 1px solid var(--brt-border-color);
        font-size: 0.875rem;
        color: var(--brt-text-dark);
        background-color: #FAFAFA;
        padding: 0.6rem 0.85rem;
        transition: all 0.2s ease;
    }

    .form-control-custom:focus, .form-select-custom:focus {
        background-color: #FFFFFF;
        border-color: var(--brt-gold-accent);
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
    }

    .btn-brt-gold {
        background: var(--brt-gold-accent);
        color: #FFFFFF;
        font-weight: 700;
        font-size: 0.875rem;
        height: 44px;
        border-radius: 22px;
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);
    }

    .btn-brt-gold:hover {
        background: var(--brt-gold-hover);
        color: #FFFFFF;
        box-shadow: 0 6px 16px rgba(217, 119, 6, 0.3);
    }

    /* Alert Styling */
    .brt-alert-success {
        background: #F0FDF4;
        border: 1px solid #BBF7D0;
        border-left: 5px solid #16A34A;
        border-radius: 12px;
        padding: 0.9rem 1.25rem;
        color: #15803D;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }
</style>

<!-- Header Section -->
<div class="page-header-container d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <span class="eyebrow-text">ORDER FULFILLMENT</span>
        <h3 class="page-title">Order #@Model.OrderNumber</h3>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold">
        ← Back to Orders
    </a>
</div>

<!-- Flash Success Alert -->
@if (TempData["Success"] != null)
{
    <div class="brt-alert-success d-flex align-items-center gap-2">
        <span class="material-symbols-outlined fs-5">check_circle</span>
        <span>@TempData["Success"]</span>
    </div>
}

<div class="row g-4">
    <!-- Left Column: Order Information & Items -->
    <div class="col-lg-7">
        
        <!-- Buyer Details Card -->
        <div class="details-card">
            <h5 class="card-title-custom">
                <span class="material-symbols-outlined fs-5 text-warning">person</span>
                Buyer Details
            </h5>
            <div class="mb-3">
                <h6 class="fw-bold text-dark mb-0 fs-6">@Model.BuyerName</h6>
                <span class="text-muted small">@Model.BusinessName</span>
            </div>
            
            <div class="d-flex flex-wrap gap-2 mb-3">
                <a href="tel:@Model.PhoneNumber" class="btn-action-call">
                    <span class="material-symbols-outlined fs-6">call</span>
                    <span>@Model.PhoneNumber</span>
                </a>
                <a href="https://api.whatsapp.com/send?phone=91@Model.PhoneNumber" target="_blank" class="btn-action-whatsapp">
                    <span class="material-symbols-outlined fs-6">chat</span>
                    <span>WhatsApp</span>
                </a>
            </div>

            @if (!string.IsNullOrEmpty(Model.BuyerAddress))
            {
                <div class="text-muted small d-flex align-items-start gap-1">
                    <span class="material-symbols-outlined fs-6 mt-1">location_on</span>
                    <span>@Model.BuyerAddress, <strong>@Model.City</strong></span>
                </div>
            }
        </div>

        <!-- Order Items Summary Table -->
        <div class="details-card">
            <h5 class="card-title-custom">
                <span class="material-symbols-outlined fs-5 text-warning">inventory_2</span>
                Order Items
            </h5>
            <div class="table-responsive mb-3">
                <table class="table table-invoice">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Packing</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Est. Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold text-dark">@item.Product?.Name</td>
                            <td><span class="badge bg-light text-dark border">@item.PackingType?.PackSize</span></td>
                            <td class="text-center fw-bold">@item.Quantity</td>
                            <td class="text-end">₹@item.PriceAtOrderTime.ToString("N2")</td>
                            <td class="text-end fw-semibold">₹@item.LineEstimate.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <!-- Total Banner -->
            <div class="total-banner d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <span class="text-muted small d-block">TOTAL ESTIMATED AMOUNT</span>
                    @if (Model.TransportChargeApplicable)
                    {
                        <span class="badge bg-warning text-dark fs-7 mt-1">+ Transport Charges Extra</span>
                    }
                </div>
                <div class="fs-4 fw-bold text-dark">
                    ₹@Model.TotalEstimatedAmount.ToString("N2")
                </div>
            </div>
        </div>

        <!-- Status Audit History Timeline -->
        <div class="details-card">
            <h5 class="card-title-custom">
                <span class="material-symbols-outlined fs-5 text-warning">history</span>
                Status History
            </h5>
            <ul class="timeline">
            @foreach (var h in Model.StatusHistory.OrderByDescending(x => x.ChangedAt))
            {
                <li class="timeline-item">
                    <div class="timeline-point"></div>
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small fw-bold text-dark">
                                @h.OldStatus → <span class="text-primary">@h.NewStatus</span>
                            </div>
                            @if (!string.IsNullOrEmpty(h.Remarks))
                            {
                                <div class="text-muted small mt-1">"@h.Remarks"</div>
                            }
                        </div>
                        <span class="text-muted small font-monospace">@h.ChangedAt.ToString("dd-MMM HH:mm")</span>
                    </div>
                </li>
            }
            </ul>
        </div>

    </div>

    <!-- Right Column: Status Workflow Action Form -->
    <div class="col-lg-5">
        <div class="details-card sticky-top" style="top: 1.5rem;">
            <h5 class="card-title-custom">
                <span class="material-symbols-outlined fs-5 text-warning">published_with_changes</span>
                Update Order Status
            </h5>
            <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label class="form-label-custom">New Order Status</label>
                    <select name="newStatus" class="form-select form-select-custom" asp-items="Html.GetEnumSelectList<OrderStatus>()">
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">Expected Dispatch Date</label>
                    <input type="date" name="expectedDispatchDate" class="form-control form-control-custom" />
                </div>

                <div class="mb-4">
                    <label class="form-label-custom">Admin Remarks / Notes</label>
                    <textarea name="remarks" class="form-control form-control-custom" rows="3" placeholder="Add optional dispatch details or instructions..."></textarea>
                </div>

                <button type="submit" class="btn btn-brt-gold w-100 d-flex align-items-center justify-content-center gap-2">
                    <span class="material-symbols-outlined fs-5">sync</span>
                    <span>Update Status Now</span>
                </button>
            </form>
        </div>
    </div>
</div>
