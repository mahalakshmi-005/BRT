<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - BRT Admin Portal</title>
    
    <!-- Google Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@300..600,0..1&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />

    <style>
        :root {
            --brt-navy-dark: #0B132A;
            --brt-navy-sidebar: #0F172A;
            --brt-navy-hover: #1E293B;
            --brt-gold-accent: #D97706;
            --brt-gold-hover: #B45309;
            --brt-bg-light: #F8FAFC;
            --brt-border-color: #334155;
            --brt-text-muted: #94A3B8;
        }

        body.admin-body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--brt-bg-light);
            color: #0F172A;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        .admin-sidebar {
            width: 260px;
            background-color: var(--brt-navy-sidebar);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1000;
            padding: 1.25rem 1rem;
            border-right: 1px solid #1E293B;
            transition: all 0.3s ease;
        }

        /* Brand Styling */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 0.75rem 1.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .brand-om {
            font-size: 1.6rem;
            color: var(--brt-gold-accent);
            line-height: 1;
        }

        .sidebar-brand strong {
            color: #FFFFFF;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            display: block;
            line-height: 1.2;
        }

        .sidebar-brand small {
            color: var(--brt-text-muted);
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Sidebar Nav Links */
        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            margin-top: 1.25rem;
            flex-grow: 1;
            overflow-y: auto;
        }

        .sidebar-nav-item {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            padding: 0.7rem 0.9rem;
            color: var(--brt-text-muted);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 10px;
            transition: all 0.2s ease;
        }

        .sidebar-nav-item .material-symbols-outlined {
            font-size: 1.25rem;
            color: #64748B;
            transition: color 0.2s ease;
        }

        .sidebar-nav-item:hover {
            background: var(--brt-navy-hover);
            color: #F8FAFC;
        }

        .sidebar-nav-item:hover .material-symbols-outlined {
            color: var(--brt-gold-accent);
        }

        .sidebar-nav-item.active {
            background: rgba(217, 119, 6, 0.12);
            color: var(--brt-gold-accent);
            font-weight: 600;
            border-left: 3px solid var(--brt-gold-accent);
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .sidebar-nav-item.active .material-symbols-outlined {
            color: var(--brt-gold-accent);
        }

        /* Sidebar Footer / Logout */
        .sidebar-logout {
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .btn-logout-custom {
            border: 1px solid #334155;
            background: rgba(255, 255, 255, 0.03);
            color: #CBD5E1;
            font-weight: 600;
            font-size: 0.825rem;
            padding: 0.6rem;
            border-radius: 10px;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
        }

        .btn-logout-custom:hover {
            background: #EF4444;
            border-color: #EF4444;
            color: #FFFFFF;
        }

        /* Main Content Container */
        .admin-main {
            margin-left: 260px;
            flex-grow: 1;
            padding: 2rem;
            min-height: 100vh;
            width: calc(100% - 260px);
        }

        @@media (max-width: 991.88px) {
            .admin-sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }
            .admin-main {
                margin-left: 0;
                width: 100%;
                padding: 1.25rem;
            }
            .admin-wrapper {
                flex-direction: column;
            }
        }
    </style>
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <!-- Sidebar Navigation -->
        <aside class="admin-sidebar">
            <div>
                <!-- Brand Info -->
                <div class="sidebar-brand">
                    <span class="brand-om">🕉</span>
                    <div>
                        <strong>BRT Admin</strong>
                        <small>B Raj Traders</small>
                    </div>
                </div>

                <!-- Navigation List -->
                <nav class="sidebar-nav">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    }

                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Dashboard" ? "active" : "")">
                        <span class="material-symbols-outlined">dashboard</span>
                        <span>Dashboard</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Category" ? "active" : "")">
                        <span class="material-symbols-outlined">category</span>
                        <span>Categories</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Product" ? "active" : "")">
                        <span class="material-symbols-outlined">inventory_2</span>
                        <span>Products</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Price" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Price" ? "active" : "")">
                        <span class="material-symbols-outlined">payments</span>
                        <span>Market Prices</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Order" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Order" ? "active" : "")">
                        <span class="material-symbols-outlined">shopping_bag</span>
                        <span>Orders</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Content" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Content" ? "active" : "")">
                        <span class="material-symbols-outlined">article</span>
                        <span>Website Content</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index" 
                       class="sidebar-nav-item @(currentController == "Settings" ? "active" : "")">
                        <span class="material-symbols-outlined">settings</span>
                        <span>Settings</span>
                    </a>

                    <a asp-area="Admin" asp-controller="Account" asp-action="ChangePassword" 
                       class="sidebar-nav-item @(currentController == "Account" && currentAction == "ChangePassword" ? "active" : "")">
                        <span class="material-symbols-outlined">lock_reset</span>
                        <span>Change Password</span>
                    </a>
                </nav>
            </div>

            <!-- Logout Section -->
            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="sidebar-logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout-custom">
                    <span class="material-symbols-outlined fs-6">logout</span>
                    <span>Sign Out</span>
                </button>
            </form>
        </aside>

        <!-- Main Body View Container -->
        <main class="admin-main">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
