@model List<MarketHighlight>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Market Highlights";
}

<style>
    :root {
        --brt-navy-dark: #0B132A;
        --brt-gold-accent: #D97706;
        --brt-gold-hover: #B45309;
        --brt-border-color: #E2E8F0;
        --brt-text-dark: #0F172A;
        --brt-text-muted: #64748B;
    }

    /* Header Section */
    .page-header-container {
        margin-bottom: 1.5rem;
    }

    .eyebrow-text {
        color: var(--brt-gold-accent);
        font-size: 0.725rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.2rem;
    }

    .page-title {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0;
    }

    /* Form Card */
    .content-card {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.02);
    }

    .form-control-custom, .form-select-custom {
        height: 42px;
        border-radius: 10px;
        border: 1px solid var(--brt-border-color);
        font-size: 0.85rem;
        color: var(--brt-text-dark);
        background-color: #FAFAFA;
        padding: 0.5rem 0.85rem;
        transition: all 0.2s ease;
    }

    .form-control-custom:focus, .form-select-custom:focus {
        background-color: #FFFFFF;
        border-color: var(--brt-gold-accent);
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
    }

    .btn-brt-gold {
        background: var(--brt-gold-accent);
        color: #FFFFFF;
        font-weight: 700;
        font-size: 0.85rem;
        height: 42px;
        border-radius: 10px;
        border: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
    }

    .btn-brt-gold:hover {
        background: var(--brt-gold-hover);
        color: #FFFFFF;
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.25);
    }

    /* Table Container Styling */
    .table-card-container {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
    }

    .table-custom {
        margin-bottom: 0;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-custom th {
        background: #F8FAFC;
        color: var(--brt-text-muted);
        font-size: 0.725rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        padding: 0.9rem 1.25rem;
        border-bottom: 1px solid var(--brt-border-color);
    }

    .table-custom td {
        padding: 1rem 1.25rem;
        vertical-align: middle;
        color: var(--brt-text-dark);
        font-size: 0.875rem;
        border-bottom: 1px solid #F1F5F9;
        transition: background 0.2s ease;
    }

    .table-custom tbody tr:last-child td {
        border-bottom: none;
    }

    .table-custom tbody tr:hover td {
        background-color: #F8FAFC;
    }

    /* Trend Badges */
    .badge-trend {
        padding: 0.35rem 0.8rem;
        border-radius: 20px;
        font-size: 0.725rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .badge-trend-up { background: #DCFCE7; color: #15803D; }
    .badge-trend-down { background: #FEE2E2; color: #B91C1C; }
    .badge-trend-stable { background: #F1F5F9; color: #475569; }
</style>

<!-- Header Section -->
<div class="page-header-container">
    <span class="eyebrow-text">LIVE MANDI TICKER</span>
    <h3 class="page-title">Today's Market Highlights</h3>
    <p class="text-muted small mb-0 mt-1">These highlights appear on the homepage marquee — e.g. "MP Garlic ↑", "Jeera ↓", "Cardamom Fresh Stock".</p>
</div>

<!-- Add Highlight Form Card -->
<div class="content-card mb-4">
    <h6 class="fw-bold text-dark mb-3">Add New Highlight</h6>
    <form asp-action="AddHighlight" method="post" class="row g-2">
        @Html.AntiForgeryToken()
        <div class="col-md-4">
            <select name="productId" class="form-select form-select-custom" asp-items="ViewBag.Products">
                <option value="">-- Select Product (Optional) --</option>
            </select>
        </div>
        <div class="col-md-4">
            <input name="highlightText" class="form-control form-control-custom" placeholder="e.g. MP Garlic ↑" required />
        </div>
        <div class="col-md-3">
            <select name="trendDirection" class="form-select form-select-custom" asp-items="Html.GetEnumSelectList<TrendDirection>()">
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-brt-gold w-100">
                <span>Add</span>
            </button>
        </div>
    </form>
</div>

<!-- Highlights Table Card -->
<div class="table-card-container">
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Highlight Text</th>
                    <th>Trend Direction</th>
                    <th>Display Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var h in Model)
                {
                    var trendStr = h.TrendDirection.ToString().ToLower();
                    var badgeClass = trendStr switch
                    {
                        "up" or "bullish" => "badge-trend-up",
                        "down" or "bearish" => "badge-trend-down",
                        _ => "badge-trend-stable"
                    };

                    var trendIcon = trendStr switch
                    {
                        "up" or "bullish" => "trending_up",
                        "down" or "bearish" => "trending_down",
                        _ => "trending_flat"
                    };

                    <tr>
                        <td class="fw-bold text-dark">@h.HighlightText</td>
                        <td>
                            <span class="badge-trend @badgeClass">
                                <span class="material-symbols-outlined fs-6 align-middle">@trendIcon</span>
                                @h.TrendDirection
                            </span>
                        </td>
                        <td class="text-secondary small">@h.DisplayDate.ToString("dd-MMM-yyyy")</td>
                        <td class="text-end">
                            <form asp-action="DeleteHighlight" asp-route-id="@h.Id" method="post" class="d-inline" onsubmit="return confirm('Remove this market highlight?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-pill px-2" title="Remove">
                                    <span class="material-symbols-outlined fs-6 align-middle">delete</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-5 text-muted">
                        <span class="material-symbols-outlined fs-1 text-secondary d-block mb-2">campaign</span>
                        <div class="fw-bold fs-6">No Market Highlights Active</div>
                        <span class="small">Add a new market highlight above to display on the live ticker.</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
