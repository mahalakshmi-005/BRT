@model List<Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Market Prices";
    var todaysPrices = (Dictionary<int, MarketPrice>)ViewBag.TodaysPrices;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Today's Market Prices</h3>
    <a asp-action="Highlights" class="btn btn-outline-secondary">Manage Market Highlights</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-hover bg-white align-middle">
    <thead>
        <tr><th>Product</th><th>Previous Price</th><th>Today's Price</th><th>Difference</th><th>GST Included</th><th>Update</th></tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        var hasPrice = todaysPrices.ContainsKey(p.Id);
        var mp = hasPrice ? todaysPrices[p.Id] : null;
        <tr>
            <td>@p.Name <small class="text-muted">(@p.SubCategory?.Name)</small></td>
            <td>@(mp?.PreviousPrice.ToString("F2") ?? "-")</td>
            <td>@(mp?.TodayPrice.ToString("F2") ?? "-")</td>
            <td>
                @if (mp != null)
                {
                    var diff = mp.PriceDifference;
                    var diffClass = diff > 0 ? "text-success" : diff < 0 ? "text-danger" : "text-muted";
                    var diffIcon = diff > 0 ? "arrow_upward" : diff < 0 ? "arrow_downward" : "remove";
                    <span class="@diffClass">
                        <span class="material-symbols-outlined" style="font-size:1rem">@diffIcon</span> @diff.ToString("F2")
                    </span>
                }
            </td>
            <td>@(mp?.GSTIncluded == true ? "Yes" : "No")</td>
            <td>
                <form asp-action="UpdatePrice" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@p.Id" />
                    <input type="number" step="0.01" name="todayPrice" class="form-control form-control-sm" style="width:110px" placeholder="Price" value="@mp?.TodayPrice" required />
                    <div class="form-check">
                        <input type="checkbox" name="gstIncluded" value="true" class="form-check-input" checked />
                    </div>
                    <input type="hidden" name="updatedBy" value="@User.Identity!.Name" />
                    <button class="btn btn-sm btn-brt">Update</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
