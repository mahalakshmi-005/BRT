@model List<Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Products</h3>
    <a asp-action="Create" class="btn btn-brt">+ Add Product</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="get" class="mb-3" style="max-width:320px">
    <select name="subCategoryId" class="form-select" asp-items="ViewBag.SubCategories" onchange="this.form.submit()">
        <option value="">-- All Sub-categories --</option>
    </select>
</form>

<table class="table table-hover bg-white">
    <thead>
        <tr><th>Product</th><th>Sub-category</th><th>Grade</th><th>Packing Types</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td>
            <td>@p.SubCategory?.Category?.Name → @p.SubCategory?.Name</td>
            <td>@p.Grade</td>
            <td>@p.PackingTypes.Count(pt => pt.IsActive)</td>
            <td>@(p.IsActive ? "Active" : "Inactive")</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Remove this product?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
