@model Product
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Product";
}

<style>
    :root {
        --brt-navy-dark: #0B132A;
        --brt-gold-accent: #D97706;
        --brt-gold-hover: #B45309;
        --brt-border-color: #E2E8F0;
        --brt-text-dark: #0F172A;
        --brt-text-muted: #64748B;
    }

    /* Header Section */
    .page-header-container {
        margin-bottom: 1.5rem;
    }

    .eyebrow-text {
        color: var(--brt-gold-accent);
        font-size: 0.725rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.2rem;
    }

    .page-title {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0;
    }

    /* Cards Styling */
    .form-card-container {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        padding: 1.75rem;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
        max-width: 780px;
    }

    .card-title-custom {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-size: 1.15rem;
        font-weight: 700;
    }

    .form-label-custom {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--brt-text-dark);
        margin-bottom: 0.4rem;
        display: block;
    }

    .form-control-custom, .form-select-custom {
        border-radius: 10px;
        border: 1px solid var(--brt-border-color);
        font-size: 0.875rem;
        color: var(--brt-text-dark);
        background-color: #FAFAFA;
        padding: 0.6rem 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control-custom:focus, .form-select-custom:focus {
        background-color: #FFFFFF;
        border-color: var(--brt-gold-accent);
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
    }

    /* Upload Preview Box */
    .upload-box-wrapper {
        background: #F8FAFC;
        border: 1px dashed #CBD5E1;
        border-radius: 12px;
        padding: 1rem;
        margin-top: 0.35rem;
    }

    .image-preview-badge {
        position: relative;
        display: inline-block;
        border: 1px solid var(--brt-border-color);
        border-radius: 12px;
        padding: 4px;
        background: #FFFFFF;
    }

    .image-preview-badge img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
    }

    .divider-text {
        display: flex;
        align-items: center;
        text-align: center;
        color: var(--brt-text-muted);
        font-size: 0.75rem;
        font-weight: 600;
        margin: 0.75rem 0;
    }

    .divider-text::before, .divider-text::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid var(--brt-border-color);
    }

    .divider-text:not(:empty)::before { margin-right: .5em; }
    .divider-text:not(:empty)::after { margin-left: .5em; }

    /* Custom Checkboxes */
    .form-check-custom {
        padding-left: 1.75rem;
    }

    .form-check-custom .form-check-input {
        width: 1.15rem;
        height: 1.15rem;
        margin-left: -1.75rem;
        border-color: var(--brt-border-color);
        cursor: pointer;
    }

    .form-check-custom .form-check-input:checked {
        background-color: var(--brt-gold-accent);
        border-color: var(--brt-gold-accent);
    }

    .form-check-custom .form-check-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--brt-text-dark);
        cursor: pointer;
    }

    /* Buttons */
    .btn-brt-gold {
        background: var(--brt-gold-accent);
        color: #FFFFFF;
        font-weight: 700;
        font-size: 0.875rem;
        padding: 0.65rem 1.25rem;
        border-radius: 10px;
        border: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-brt-gold:hover {
        background: var(--brt-gold-hover);
        color: #FFFFFF;
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.25);
    }

    .btn-cancel-custom {
        border: 1px solid var(--brt-border-color);
        background: #FFFFFF;
        color: var(--brt-text-muted);
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.65rem 1.25rem;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-cancel-custom:hover {
        background: #F1F5F9;
        color: var(--brt-navy-dark);
    }

    /* Tables */
    .table-custom-sm {
        width: 100%;
        margin-bottom: 0;
    }

    .table-custom-sm th {
        background: #F8FAFC;
        color: var(--brt-text-muted);
        font-size: 0.725rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        padding: 0.65rem 0.85rem;
        border-bottom: 1px solid var(--brt-border-color);
    }

    .table-custom-sm td {
        padding: 0.65rem 0.85rem;
        vertical-align: middle;
        font-size: 0.85rem;
        border-bottom: 1px solid #F1F5F9;
    }

    /* Alerts */
    .brt-alert-success {
        background: #F0FDF4;
        border: 1px solid #BBF7D0;
        border-left: 5px solid #16A34A;
        border-radius: 12px;
        padding: 0.9rem 1.25rem;
        color: #15803D;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }
</style>

<!-- Header Section -->
<div class="page-header-container">
    <span class="eyebrow-text">CATALOG MANAGEMENT</span>
    <h3 class="page-title">Edit Product</h3>
</div>

<!-- Dynamic Alerts -->
@if (TempData["Success"] != null)
{
    <div class="brt-alert-success d-flex align-items-center gap-2">
        <span class="material-symbols-outlined fs-5">check_circle</span>
        <span>@TempData["Success"]</span>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger rounded-3 mb-4">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div class="d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">error</span>
                <span>@err.ErrorMessage</span>
            </div>
        }
    </div>
}

<!-- Product Main Details Card -->
<div class="form-card-container mb-4">
    <h5 class="card-title-custom mb-3">Product Information</h5>
    
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Sub-Category -->
        <div class="mb-3.5">
            <label class="form-label-custom">Sub-Category</label>
            <select asp-for="SubCategoryId" class="form-select form-select-custom" asp-items="ViewBag.SubCategoryList"></select>
        </div>

        <!-- Names Row -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label-custom">Product Name (English)</label>
                <input asp-for="Name" class="form-control form-control-custom" required />
            </div>
            <div class="col-md-6">
                <label class="form-label-custom">Product Name (Tamil)</label>
                <input asp-for="NameTamil" class="form-control form-control-custom" placeholder="தமிழ் பெயர்" />
            </div>
        </div>

        <!-- Grade & HSN Code Row -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label-custom">Grade</label>
                <input asp-for="Grade" class="form-control form-control-custom" placeholder="e.g. Bomb / AAA" />
            </div>
            <div class="col-md-6">
                <label class="form-label-custom">HSN Code</label>
                <input asp-for="HSNCode" class="form-control form-control-custom" />
            </div>
        </div>

        <!-- Description -->
        <div class="mb-3.5">
            <label class="form-label-custom">Description</label>
            <textarea asp-for="Description" class="form-control form-control-custom" rows="2"></textarea>
        </div>

        <!-- Product Image Section -->
        <div class="mb-3.5">
            <label class="form-label-custom">Product Image</label>
            <div class="upload-box-wrapper">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2 d-flex align-items-center gap-3">
                        <div class="image-preview-badge">
                            <img src="@Model.ImageUrl" alt="@Model.Name" />
                        </div>
                        <span class="text-muted small">Current uploaded thumbnail</span>
                    </div>
                }
                <div>
                    <input type="file" name="imageFile" class="form-control form-control-custom" accept=".jpg,.jpeg,.png,.webp,.gif" />
                    <span class="text-muted small mt-1 d-block">Upload a new photo to replace existing image</span>
                </div>
                
                <div class="divider-text">OR</div>

                <div>
                    <input asp-for="ImageUrl" class="form-control form-control-custom" placeholder="or paste an image URL" />
                </div>
            </div>
        </div>

        <!-- Flags -->
        <div class="d-flex gap-4 mb-4 mt-3">
            <div class="form-check form-check-custom">
                <input asp-for="IsLooseAvailable" class="form-check-input" id="looseCheck" />
                <label class="form-check-label" for="looseCheck">Available in loose retail packs</label>
            </div>
            <div class="form-check form-check-custom">
                <input asp-for="IsActive" class="form-check-input" id="activeCheck" />
                <label class="form-check-label" for="activeCheck">Active Product</label>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex align-items-center gap-2 pt-2 border-top">
            <button type="submit" class="btn btn-brt-gold">
                <span class="material-symbols-outlined fs-6">save</span>
                <span>Update Product</span>
            </button>
            <a asp-action="Index" class="btn btn-cancel-custom">Back to List</a>
        </div>
    </form>
</div>

<!-- Packing Types Management Card -->
<div class="form-card-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="card-title-custom mb-0">Packing Types & Stock</h5>
        <span class="badge bg-light text-dark border">@Model.PackingTypes.Count(x => x.IsActive) Configured</span>
    </div>

    <!-- Packing Types Table -->
    <div class="table-responsive rounded-3 border mb-4">
        <table class="table-custom-sm">
            <thead>
                <tr>
                    <th>Pack Size</th>
                    <th>Unit</th>
                    <th>Wholesale</th>
                    <th>Loose</th>
                    <th>Stock Qty</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.PackingTypes != null && Model.PackingTypes.Any(x => x.IsActive))
            {
                @foreach (var pt in Model.PackingTypes.Where(x => x.IsActive))
                {
                    <tr>
                        <td class="fw-bold text-dark">@pt.PackSize</td>
                        <td><span class="badge bg-light text-dark border">@pt.PackUnit</span></td>
                        <td>
                            @if(pt.IsWholesale) {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">Yes</span>
                            } else {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if(pt.IsLoose) {
                                <span class="badge bg-info-subtle text-info border border-info-subtle">Yes</span>
                            } else {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="fw-semibold">@pt.StockQuantity</td>
                        <td class="text-end">
                            <form asp-action="DeletePackingType" asp-route-id="@pt.Id" asp-route-productId="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Remove packing type?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle p-1" title="Delete">
                                    <span class="material-symbols-outlined fs-6 align-middle">delete</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted small">
                        No packing types active for this product yet.
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <!-- Add Packing Type Form -->
    <div class="bg-light p-3 rounded-3 border">
        <h6 class="fw-bold text-dark mb-3 small text-uppercase">Add New Packing Type</h6>
        <form asp-action="AddPackingType" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductId" value="@Model.Id" />
            
            <div class="col-md-3">
                <label class="form-label-custom small">Pack Size</label>
                <input name="PackSize" class="form-control form-control-custom form-control-sm" placeholder="e.g. 30 Bag" required />
            </div>
            
            <div class="col-md-2">
                <label class="form-label-custom small">Unit</label>
                <select name="PackUnit" class="form-select form-select-custom form-select-sm">
                    <option value="KG">KG</option>
                    <option value="G">G</option>
                </select>
            </div>
            
            <div class="col-md-2">
                <label class="form-label-custom small">Stock Qty</label>
                <input name="StockQuantity" type="number" class="form-control form-control-custom form-control-sm" value="0" />
            </div>
            
            <div class="col-md-2">
                <div class="form-check form-check-custom pt-3">
                    <input type="checkbox" name="IsWholesale" value="true" class="form-check-input" id="wsCheck" checked />
                    <label class="form-check-label small" for="wsCheck">Wholesale</label>
                </div>
            </div>
            
            <div class="col-md-2">
                <div class="form-check form-check-custom pt-3">
                    <input type="checkbox" name="IsLoose" value="true" class="form-check-input" id="lsCheck" />
                    <label class="form-check-label small" for="lsCheck">Loose</label>
                </div>
            </div>
            
            <div class="col-md-1">
                <button type="submit" class="btn btn-brt-gold btn-sm w-100 justify-content-center">
                    <span>Add</span>
                </button>
            </div>
        </form>
    </div>
</div>
