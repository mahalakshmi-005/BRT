@model Product
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Product";
}
<h3 class="mb-4">Add Product</h3>
<div class="admin-card" style="max-width:600px">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label class="form-label">Sub-category</label>
            <select asp-for="SubCategoryId" class="form-select" asp-items="ViewBag.SubCategoryList"></select>
        </div>
        <div class="mb-3">
            <label class="form-label">Product Name (English)</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. MP Garlic Bomb" />
        </div>
        <div class="mb-3">
            <label class="form-label">Product Name (Tamil)</label>
            <input asp-for="NameTamil" class="form-control" placeholder="e.g. எம்பி பூண்டு பாம்ப்" />
        </div>
        <div class="mb-3">
            <label class="form-label">Grade</label>
            <input asp-for="Grade" class="form-control" placeholder="e.g. Bomb / AAA / Bold" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Product Image</label>
            <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.gif" />
            <small class="text-muted">Upload a photo (JPG/PNG/WEBP, max 5MB) — or leave blank and paste a URL below.</small>
            <input asp-for="ImageUrl" class="form-control mt-2" placeholder="or paste an image URL" />
        </div>
        <div class="mb-3">
            <label class="form-label">HSN Code</label>
            <input asp-for="HSNCode" class="form-control" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsLooseAvailable" class="form-check-input" />
            <label class="form-check-label">Available in loose retail packs</label>
        </div>
        <button class="btn btn-brt">Save &amp; Continue to Packing Types</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
