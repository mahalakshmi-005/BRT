@model ChangePasswordViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Change Password";
}

<style>
    :root {
        --brt-navy-dark: #0B132A;
        --brt-gold-accent: #D97706;
        --brt-gold-hover: #B45309;
        --brt-border-color: #E2E8F0;
        --brt-text-dark: #0F172A;
        --brt-text-muted: #64748B;
    }

    /* Page Title & Header */
    .page-header-container {
        margin-bottom: 2rem;
    }

    .eyebrow-text {
        color: var(--brt-gold-accent);
        font-size: 0.725rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.2rem;
    }

    .page-title {
        font-family: Georgia, serif;
        color: var(--brt-navy-dark);
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0;
    }

    /* Card Box */
    .form-card-container {
        background: #FFFFFF;
        border: 1px solid var(--brt-border-color);
        border-radius: 16px;
        padding: 2.25rem 2rem;
        max-width: 480px;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
    }

    /* Input Styles */
    .form-label-custom {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--brt-text-dark);
        margin-bottom: 0.4rem;
    }

    .input-group-custom {
        position: relative;
    }

    .input-group-custom .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94A3B8;
        font-size: 1.2rem;
        z-index: 5;
    }

    .form-control-custom {
        padding-left: 2.6rem !important;
        padding-right: 2.6rem !important;
        height: 46px;
        border-radius: 10px;
        border: 1px solid var(--brt-border-color);
        font-size: 0.9rem;
        color: var(--brt-text-dark);
        background-color: #FAFAFA;
        transition: all 0.2s ease;
    }

    .form-control-custom:focus {
        background-color: #FFFFFF;
        border-color: var(--brt-gold-accent);
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
    }

    .toggle-password-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94A3B8;
        cursor: pointer;
        z-index: 5;
        padding: 0;
        display: flex;
        align-items: center;
    }

    .toggle-password-btn:hover {
        color: var(--brt-text-dark);
    }

    /* Gold CTA Button */
    .btn-brt-gold {
        background: var(--brt-gold-accent);
        color: #FFFFFF;
        font-weight: 700;
        font-size: 0.875rem;
        letter-spacing: 0.5px;
        height: 46px;
        border-radius: 25px;
        border: none;
        text-transform: uppercase;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);
    }

    .btn-brt-gold:hover {
        background: var(--brt-gold-hover);
        color: #FFFFFF;
        box-shadow: 0 6px 16px rgba(217, 119, 6, 0.3);
        transform: translateY(-1px);
    }

    /* Alert Styling */
    .brt-alert-success {
        background: #F0FDF4;
        border: 1px solid #BBF7D0;
        border-left: 5px solid #16A34A;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        color: #15803D;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        max-width: 480px;
    }
</style>

<!-- Header Section -->
<div class="page-header-container">
    <span class="eyebrow-text">SECURITY SETTINGS</span>
    <h3 class="page-title">Change Password</h3>
</div>

<!-- Success Flash Alert -->
@if (TempData["Success"] != null)
{
    <div class="brt-alert-success d-flex align-items-center gap-2">
        <span class="material-symbols-outlined fs-5">check_circle</span>
        <span>@TempData["Success"]</span>
    </div>
}

<!-- Main Form Card -->
<div class="form-card-container">
    <form asp-action="ChangePassword" method="post" novalidate>
        @Html.AntiForgeryToken()

        <!-- Validation Summary Alert -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 rounded-3 py-2 small mb-3">
                <div asp-validation-summary="All" class="text-danger small mb-0"></div>
            </div>
        }

        <!-- Current Password -->
        <div class="mb-3">
            <label class="form-label-custom">Current Password</label>
            <div class="input-group-custom">
                <input asp-for="CurrentPassword" id="currentPasswordInput" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                <span class="material-symbols-outlined input-icon">lock</span>
                <button type="button" class="toggle-password-btn" onclick="togglePassword('currentPasswordInput', 'currentToggleIcon')">
                    <span class="material-symbols-outlined" id="currentToggleIcon">visibility</span>
                </button>
            </div>
            <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <!-- New Password -->
        <div class="mb-3">
            <label class="form-label-custom">New Password</label>
            <div class="input-group-custom">
                <input asp-for="NewPassword" id="newPasswordInput" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                <span class="material-symbols-outlined input-icon">key</span>
                <button type="button" class="toggle-password-btn" onclick="togglePassword('newPasswordInput', 'newToggleIcon')">
                    <span class="material-symbols-outlined" id="newToggleIcon">visibility</span>
                </button>
            </div>
            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <!-- Confirm New Password -->
        <div class="mb-4">
            <label class="form-label-custom">Confirm New Password</label>
            <div class="input-group-custom">
                <input asp-for="ConfirmPassword" id="confirmPasswordInput" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                <span class="material-symbols-outlined input-icon">verified_user</span>
                <button type="button" class="toggle-password-btn" onclick="togglePassword('confirmPasswordInput', 'confirmToggleIcon')">
                    <span class="material-symbols-outlined" id="confirmToggleIcon">visibility</span>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-brt-gold w-100 d-flex align-items-center justify-content-center gap-2">
            <span>Update Password</span>
            <span class="material-symbols-outlined fs-5">shield</span>
        </button>
    </form>
</div>

<!-- Password Toggle Script -->
<script>
    function togglePassword(inputId, iconId) {
        const passwordInput = document.getElementById(inputId);
        const toggleIcon = document.getElementById(iconId);
        
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            toggleIcon.textContent = 'visibility_off';
        } else {
            passwordInput.type = 'password';
            toggleIcon.textContent = 'visibility';
        }
    }
</script>
