@model BRT.Areas.Admin.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Portal Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Portal - B Raj Traders</title>
    <!-- Bootstrap 5.3 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Google Material Symbols & Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

    <style>
        :root {
            --brt-bg-white: #FFFFFF;
            --brt-navy-dark: #0B132A;
            --brt-navy-card: #0F172A;
            --brt-gold-accent: #D97706;
            --brt-gold-light: #FFFBEB;
            --brt-text-dark: #1E293B;
            --brt-text-muted: #64748B;
            --brt-border-color: #E2E8F0;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #F8FAFC;
            position: relative;
            padding: 2rem 1rem;
        }

        /* Minimalist Outer Wrapper */
        .login-wrapper {
            width: 100%;
            max-width: 440px;
        }

        /* Top Eyebrow Title */
        .eyebrow-text {
            color: var(--brt-gold-accent);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .main-heading {
            font-family: Georgia, serif;
            color: var(--brt-text-dark);
            font-weight: 700;
            font-size: 2rem;
            margin-top: 0.25rem;
            margin-bottom: 0.5rem;
        }

        .sub-heading {
            color: var(--brt-text-muted);
            font-size: 0.85rem;
            margin-bottom: 2rem;
        }

        /* Main Login Card - Clean White Theme */
        .login-card {
            background: var(--brt-bg-white);
            border: 1px solid var(--brt-border-color);
            border-radius: 16px;
            padding: 2.5rem 2rem;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
            transition: all 0.3s ease;
        }

        .login-card:hover {
            border-color: #CBD5E1;
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
        }

        /* Form Controls */
        .form-label-custom {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--brt-text-dark);
            margin-bottom: 0.4rem;
        }

        .input-group-custom {
            position: relative;
        }

        .input-group-custom .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94A3B8;
            font-size: 1.2rem;
            z-index: 5;
        }

        .form-control-custom {
            padding-left: 2.6rem !important;
            padding-right: 2.6rem;
            height: 46px;
            border-radius: 10px;
            border: 1px solid var(--brt-border-color);
            font-size: 0.9rem;
            color: var(--brt-text-dark);
            background-color: #FAFAFA;
            transition: all 0.2s ease;
        }

        .form-control-custom:focus {
            background-color: #FFFFFF;
            border-color: var(--brt-gold-accent);
            box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.15);
        }

        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94A3B8;
            cursor: pointer;
            z-index: 5;
            padding: 0;
            display: flex;
            align-items: center;
        }

        /* Golden Primary Button (Matches Website CTA) */
        .btn-brt-gold {
            background: var(--brt-gold-accent);
            color: #FFFFFF;
            font-weight: 700;
            font-size: 0.875rem;
            letter-spacing: 0.5px;
            height: 46px;
            border-radius: 25px; /* Pill Shape like 'BROWSE WHOLESALE PRODUCTS' button */
            border: none;
            text-transform: uppercase;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);
        }

        .btn-brt-gold:hover {
            background: #B45309;
            color: #FFFFFF;
            box-shadow: 0 6px 16px rgba(217, 119, 6, 0.3);
            transform: translateY(-1px);
        }

        .form-check-input:checked {
            background-color: var(--brt-gold-accent);
            border-color: var(--brt-gold-accent);
        }

        /* Bottom Dark Footer (Matches Website Footer Section) */
        .website-style-footer {
            background-color: var(--brt-navy-dark);
            border-radius: 12px;
            padding: 1.25rem;
            margin-top: 1.5rem;
            color: #FFFFFF;
            text-align: center;
        }

        .om-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background: var(--brt-gold-light);
            color: var(--brt-gold-accent);
            border-radius: 8px;
            font-size: 1.2rem;
            margin-bottom: 0.75rem;
            border: 1px solid rgba(217, 119, 6, 0.2);
        }
    </style>
</head>
<body>

    <div class="login-wrapper text-center">
        <!-- Eyebrow Title & Header -->
        <span class="eyebrow-text">B RAJ TRADERS ADMIN</span>
        <h1 class="main-heading">Management Portal</h1>
        <p class="sub-heading">Garlic &amp; Grocery Commission Mandi Portal Access</p>

        <!-- Main Clean Login Card -->
        <div class="login-card text-start">
            <div class="text-center">
                <div class="om-badge">🕉</div>
            </div>

            <!-- Login Form -->
            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <!-- ASP.NET Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 py-2 small mb-3" role="alert" style="display:none"></div>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-3 py-2 small mb-3">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div class="d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined fs-6">error</span>
                                <span>@err.ErrorMessage</span>
                            </div>
                        }
                    </div>
                }

                <!-- Email Field -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label-custom">Email Address</label>
                    <div class="input-group-custom">
                        <input asp-for="Email" class="form-control form-control-custom" placeholder="admin@brajtraders.com" autocomplete="username" />
                        <span class="material-symbols-outlined input-icon">mail</span>
                    </div>
                </div>

                <!-- Password Field -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label-custom">Password</label>
                    <div class="input-group-custom">
                        <input asp-for="Password" id="passwordInput" type="password" class="form-control form-control-custom" placeholder="••••••••" autocomplete="current-password" />
                        <span class="material-symbols-outlined input-icon">lock</span>
                        <button type="button" class="toggle-password" onclick="togglePasswordVisibility()">
                            <span class="material-symbols-outlined" id="toggleIcon">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="form-check mb-0">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMeCheck" />
                        <label asp-for="RememberMe" class="form-check-label small text-secondary fw-medium" for="rememberMeCheck">
                            Keep me signed in
                        </label>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-brt-gold w-100 d-flex align-items-center justify-content-center gap-2">
                    <span>Login to Dashboard</span>
                    <span class="material-symbols-outlined fs-5">arrow_forward</span>
                </button>
            </form>
        </div>

        <!-- Matching Navy Dark Bottom Card -->
        <div class="website-style-footer d-flex align-items-center justify-content-center gap-2">
            <span class="material-symbols-outlined text-warning fs-6">verified_user</span>
            <span class="extra-small text-light opacity-75" style="font-size: 0.78rem;">Authorized Personnel Only • BRT Mandi System</span>
        </div>
    </div>

    <!-- Password Show/Hide Script -->
    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('passwordInput');
            const toggleIcon = document.getElementById('toggleIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.textContent = 'visibility_off';
            } else {
                passwordInput.type = 'password';
                toggleIcon.textContent = 'visibility';
            }
        }
    </script>
</body>
</html>
