@model BRT.Areas.Admin.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login - BRT</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0b3d24 0%, #10552f 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .login-card {
            background: #fff;
            border-radius: 14px;
            padding: 2.5rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .login-card h2 { color: #0b3d24; font-weight: 700; }
        .om-symbol { text-align: center; font-size: 2rem; color: #c9a227; }
        .brand-sub { text-align: center; color: #6b7280; font-size: 0.85rem; margin-bottom: 1.5rem; }
        .btn-brt { background: #0b3d24; color: #fff; border: none; }
        .btn-brt:hover { background: #10552f; color: #fff; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="om-symbol">🕉</div>
        <h2 class="text-center">BRT Admin</h2>
        <div class="brand-sub">B Raj Traders — Garlic &amp; Grocery Commission Mandi</div>

        <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert" style="display:none"></div>
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" autocomplete="username" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>
            <button type="submit" class="btn btn-brt w-100 py-2">Login</button>
        </form>
    </div>
</body>
</html>
