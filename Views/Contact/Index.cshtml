@{
    var settings = (Dictionary<string, string>)ViewBag.Settings;
}

<!-- High-End Architecture Fonts & Elements -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;700&family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<style>
    :root {
        --brt-dark-abyss: #0B0F17;
        --brt-gold-pure: #D4AF37;
        --brt-gold-gradient: linear-gradient(135deg, #F3E7C4 0%, #D4AF37 50%, #8A6F27 100%);
        --glass-bg: rgba(255, 255, 255, 0.85);
        --glass-border: rgba(226, 232, 240, 0.8);
        --text-headline: #0F172A;
        --text-body: #475569;
        --neon-green: #22C55E;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #F8FAFC;
        color: var(--text-headline);
    }

    /* LANG DISCONNECT SWITCH ENGINE */
    html[lang="en"] .lang-en-node { display: block !important; }
    html[lang="en"] .lang-ta-node { display: none !important; }
    html[lang="ta"] .lang-en-node { display: none !important; }
    html[lang="ta"] .lang-ta-node { display: block !important; }

    html[lang="en"] .lang-en-inline { display: inline-block !important; }
    html[lang="en"] .lang-ta-inline { display: none !important; }
    html[lang="ta"] .lang-en-inline { display: none !important; }
    html[lang="ta"] .lang-ta-inline { display: inline-block !important; }

    /* HIGH-LEVEL ENTERPRISE HERO GRID */
    .premium-hero-canopy {
        background: radial-gradient(120% 120% at 50% 0%, rgba(212, 175, 55, 0.07) 0%, rgba(248, 250, 252, 0) 100%), #FFFFFF;
        padding: 60px 20px 40px 20px;
        border-bottom: 1px solid var(--glass-border);
        text-align: center;
        position: relative;
    }

    .hero-badge-pill {
        display: inline-flex;
        padding: 6px 16px;
        background: rgba(212, 175, 55, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.25);
        color: #927218;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 20px;
    }

    .premium-hero-canopy h1 {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 3.5rem;
        letter-spacing: -0.03em;
        color: var(--brt-dark-abyss);
        margin-bottom: 16px;
    }

    .premium-hero-canopy p {
        color: var(--text-body);
        font-size: 1.1rem;
        max-width: 620px;
        margin: 0 auto;
        font-weight: 400;
    }

    /* ADVANCED NEO-GLASS LAYOUT ARCHITECTURE */
    .neo-glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 20px 50px -15px rgba(15, 23, 42, 0.04);
        position: relative;
        overflow: hidden;
        margin-bottom: 0px;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .neo-glass-card:hover {
        transform: translateY(-4px);
    }

    .card-grand-title {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.8rem;
        letter-spacing: -0.02em;
        margin-bottom: 24px;
        color: var(--brt-dark-abyss);
    }

    /* INNOVATIVE OWNER EXECUTIVE BADGE */
    .executive-badge {
        background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
        padding: 16px 20px;
        border-radius: 20px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .exec-meta .exec-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--brt-gold-pure);
        font-weight: 700;
    }

    .exec-meta .exec-name {
        font-size: 1.25rem;
        color: #FFFFFF;
        font-weight: 700;
        font-family: 'Space Grotesk', sans-serif;
    }

    .exec-signature {
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        color: rgba(255,255,255,0.4);
        font-size: 1.1rem;
        border-left: 1px solid rgba(255,255,255,0.1);
        padding-left: 15px;
    }

    /* PREMIUM CONNECTIVITY TILES */
    .hq-info-tile {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(241, 245, 249, 0.8);
        border-radius: 20px;
        transition: all 0.3s ease;
    }

    .hq-info-tile:hover {
        background: #FFFFFF;
        box-shadow: 0 10px 25px -10px rgba(0,0,0,0.03);
        border-color: rgba(212, 175, 55, 0.2);
    }

    .tile-icon-orb {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: var(--brt-dark-abyss);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tile-icon-orb span {
        background: var(--brt-gold-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-size: 1.5rem;
    }

    .tile-desc-text {
        font-size: 1.05rem;
        color: var(--text-headline);
        line-height: 1.6;
        font-weight: 500;
    }

    .tile-desc-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #94A3B8;
        margin-bottom: 4px;
        font-weight: 700;
    }

    /* INNOVATIVE LIVE PULSE RADAR */
    .live-radar-bar {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: #F0FDF4;
        border: 1px solid #DCFCE7;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 700;
        color: #166534;
        margin-bottom: 20px;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background-color: var(--neon-green);
        border-radius: 50%;
        position: relative;
    }

    .pulse-dot::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        background-color: var(--neon-green);
        border-radius: 50%;
        animation: pulseRadar 1.8s infinite ease-in-out;
    }

    /* LUXURY ACTION DECK */
    .luxury-action-deck {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .btn-luxury-wire {
        flex: 1;
        min-width: 100px;
        background: transparent;
        border: 2px solid var(--brt-dark-abyss);
        color: var(--brt-dark-abyss);
        font-weight: 700;
        padding: 12px 16px;
        border-radius: 14px;
        text-align: center;
        text-decoration: none !important;
        font-size: 0.88rem;
        transition: all 0.3s ease;
    }

    .btn-luxury-wire:hover {
        background: var(--brt-dark-abyss);
        color: #FFFFFF;
    }

    .btn-luxury-solid {
        flex: 1;
        min-width: 130px;
        background: #25D366;
        color: #FFFFFF !important;
        font-weight: 700;
        padding: 12px 16px;
        border-radius: 14px;
        text-align: center;
        text-decoration: none !important;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 2px solid #25D366;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px -6px rgba(37, 211, 102, 0.4);
    }

    .btn-luxury-solid:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -5px rgba(37, 211, 102, 0.5);
    }

    .btn-luxury-email {
        flex: 1;
        min-width: 120px;
        background: #EA4335;
        color: #FFFFFF !important;
        font-weight: 700;
        padding: 12px 16px;
        border-radius: 14px;
        text-align: center;
        text-decoration: none !important;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 2px solid #EA4335;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px -6px rgba(234, 67, 53, 0.4);
    }

    .btn-luxury-email:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -5px rgba(234, 67, 53, 0.5);
    }

    /* GEO FRAME & CONTROLS */
    .geo-portal-frame {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--glass-border);
        position: relative;
        background: #FFFFFF;
        box-shadow: 0 15px 40px -10px rgba(0,0,0,0.04);
    }

    .luxury-field-block {
        position: relative;
        margin-bottom: 20px;
    }

    .luxury-field-block input, .luxury-field-block textarea {
        width: 100%;
        background: rgba(241, 245, 249, 0.5);
        border: 1px solid rgba(203, 213, 225, 0.7);
        border-radius: 14px;
        padding: 14px 18px;
        font-size: 1rem;
        color: var(--text-headline);
        font-weight: 500;
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .luxury-field-block input:focus, .luxury-field-block textarea:focus {
        background: #FFFFFF;
        border-color: var(--brt-dark-abyss);
        outline: none;
        box-shadow: 0 0 0 4px rgba(11, 15, 25, 0.05);
    }

    .luxury-field-block label {
        font-size: 0.78rem;
        font-weight: 800;
        color: var(--brt-dark-abyss);
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 6px;
        display: block;
    }

    .btn-grand-dispatch {
        background: var(--brt-dark-abyss);
        color: #FFFFFF !important;
        border: none;
        width: 100%;
        padding: 16px;
        border-radius: 14px;
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px -5px rgba(11, 15, 25, 0.25);
    }

    .btn-grand-dispatch:hover {
        background: var(--brt-gold-pure);
        box-shadow: 0 10px 25px -5px rgba(212, 175, 55, 0.4);
        color: var(--brt-dark-abyss) !important;
    }

    /* HERO TRUST NODES */
    .hero-metrics-grid {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .metric-trust-node {
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(212, 175, 55, 0.2);
        padding: 12px 24px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 10px 30px -15px rgba(0, 0, 0, 0.05);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .metric-trust-node:hover {
        transform: translateY(-2px);
        border-color: var(--brt-gold-pure);
        background: #FFFFFF;
        box-shadow: 0 12px 30px -10px rgba(212, 175, 55, 0.15);
    }

    .metric-icon {
        font-size: 1.4rem !important;
        background: var(--brt-gold-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .metric-info {
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.3px;
        color: var(--brt-dark-abyss);
        text-transform: uppercase;
    }

    /* ANIMATIONS */
    .canopy-fade-in {
        animation: panelEntrance 0.7s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    }
</style>

<!-- Separate CSS to cleanly handle keyframes and media queries without Razor Engine conflicts -->
<style>
    @Html.Raw("@keyframes pulseRadar { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3.5); opacity: 0; } }")
    @Html.Raw("@keyframes panelEntrance { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }")
    
    @Html.Raw("@media(max-width: 992px) { .premium-hero-canopy h1 { font-size: 2.6rem; } .neo-glass-card { padding: 32px; } }")
    @Html.Raw("@media (max-width: 768px) { .hero-metrics-grid { gap: 12px; padding: 0 10px; } .metric-trust-node { width: 100%; justify-content: center; } }")
</style>

