                        <a href="@waUrl" target="_blank" id="contactWaBtn"
                           style="display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;font-weight:600;padding:12px 26px;border-radius:10px;text-decoration:none;margin-bottom:20px;">
                            <span class="material-symbols-outlined" style="font-size:1.1rem;">chat</span>
                            Send Details via WhatsApp
                        </a>
                        <script>
                            setTimeout(function () {
                                window.open('@Html.Raw(waUrl)', '_blank');
                            }, 1200);
                        </script>
                    }
                }

                <form asp-controller="Contact" asp-action="Submit" method="post" style="margin-bottom: 0;">
                    @Html.AntiForgeryToken()

                    <div class="luxury-field-block">
                        <label>
                            <span class="lang-en-inline">Full Identity / Name</span>
                            <span class="lang-ta-inline">முழுப் பெயர்</span>
                        </label>
                        <input name="Name" required autocomplete="off" placeholder="e.g. John Doe / எ.கா. இராமன்" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="luxury-field-block">
                                <label>
                                    <span class="lang-en-inline">Comms Line / Phone</span>
                                    <span class="lang-ta-inline">தொலைபேசி எண்</span>
                                </label>
                                <input name="Phone" required type="tel" placeholder="+91..." />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="luxury-field-block">
                                <label>
                                    <span class="lang-en-inline">Digital Mail / Email</span>
                                    <span class="lang-ta-inline">மின்னஞ்சல் முகவரி</span>
                                </label>
                                <input name="Email" type="email" placeholder="name@domain.com" />
                            </div>
                        </div>
                    </div>

                    <div class="luxury-field-block">
                        <label>
                            <span class="lang-en-inline">Transmission / Message</span>
                            <span class="lang-ta-inline">செய்தி விவரம்</span>
                        </label>
                        <textarea name="Message" rows="5" required placeholder="Outline your logistics requirements or volume targets..."></textarea>
                    </div>

                    <button type="submit" class="btn-grand-dispatch">
                        <span class="lang-en-inline">Dispatch Message</span>
                        <span class="lang-ta-inline">செய்தியை சமர்ப்பிக்க</span>
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>
