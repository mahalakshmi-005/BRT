        </div>

        <!-- Grocery Category -->
        <div class="col-lg-5 col-md-6">
            <a href="/Catalog/Grocery" class="wholesale-corporate-link">
                <div class="b2b-catalog-card">
                    <div>
                        <div class="card-meta-header">
                            <div class="b2b-avatar-holder">
                                <div class="b2b-avatar-glow-ring"></div>
                                <div class="b2b-image-avatar-frame">
                                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcScX3aq70kjbJOHPKnykVt_VO7AaOxga590lP9vuu-dBw&s=10" alt="Groceries Wholesale" />
                                </div>
                            </div>
                            <div class="live-ticker-pill">
                                <span class="blink-dot"></span>
                                <span class="lang-en">Live Index</span>
                                <span class="lang-ta">நேரடி விலை</span>
                            </div>
                        </div>
                        <h3 class="b2b-card-title">
                            <span class="lang-en">Groceries</span>
                            <span class="lang-ta">மளிகைப் பொருட்கள்</span>
                        </h3>
                        <p class="b2b-card-desc lang-en">Selected bulk spices — complete volume catalog configured with today's commercial rates.</p>
                        <p class="b2b-card-desc lang-ta">தேர்ந்தெடுக்கப்பட்ட மொத்த மசாலாப் பொருட்கள் — இன்றைய வணிக விலைகளுடன் கூடிய முழுமையான பட்டியல்.</p>
                    </div>
                    <div class="b2b-action-trigger">
                        <span class="lang-en">Browse Groceries</span>
                        <span class="lang-ta">மளிகை விவரங்கள்</span>
                        <div class="btn-circle-arrow">
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>
