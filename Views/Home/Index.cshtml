@if (ViewBag.Testimonials != null && ((IEnumerable<BRT.Models.Testimonial>)ViewBag.Testimonials).Any())
{
    <section class="container my-5 py-3">
        <h3 class="section-title fade-in-up">What Dealers Say</h3>
        <div class="row g-4">
            @foreach (var t in (IEnumerable<BRT.Models.Testimonial>)ViewBag.Testimonials)
            {
                <div class="col-md-4 fade-in-up">
                    <div class="testimonial-card">
                        <div class="stars">
                            @for (int s = 0; s < 5; s++)
                            {
                                var fillStyle = s < t.Rating ? "font-variation-settings:'FILL' 1" : "font-variation-settings:'FILL' 0";
                                <span class="material-symbols-outlined" style="@fillStyle">star</span>
                            }
                        </div>
                        <p>&ldquo;@t.Message&rdquo;</p>
                        <strong>@t.DealerName</strong>
                        <div class="text-muted small">@t.BusinessName @(!string.IsNullOrEmpty(t.City) ? $", {t.City}" : "")</div>
                    </div>
                </div>
            }
        </div>
    </section>
}

@if (ViewBag.FAQs != null && ((IEnumerable<BRT.Models.FAQ>)ViewBag.FAQs).Any())
{
    <section class="container my-5 py-3">
        <h3 class="section-title fade-in-up">Frequently Asked Questions</h3>
        <div class="accordion fade-in-up" id="faqAccordion">
            @{
                int i = 0;
            }
            @foreach (var f in (IEnumerable<BRT.Models.FAQ>)ViewBag.FAQs)
            {
                i++;
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq@(i)">
                            @f.Question
                        </button>
                    </h2>
                    <div id="faq@(i)" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">@f.Answer</div>
                    </div>
                </div>
            }
        </div>
    </section>
}

