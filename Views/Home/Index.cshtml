<!-- ===== Testimonials ===== -->
@{
    var testimonials = ViewBag.Testimonials as IEnumerable<BRT.Models.Testimonial>;
}
@if (testimonials != null && testimonials.Any())
{
    <section class="container my-5 py-4">
        <h3 class="fw-bold text-center mb-4 fade-in-up" style="color:var(--brt-green)">What Our Dealers Say</h3>
        <div class="row g-4">
            @foreach (var t in testimonials)
            {
                <div class="col-md-4 fade-in-up">
                    <div class="testimonial-card p-4 rounded-3 border bg-light h-100 shadow-sm d-flex flex-column justify-content-between">
                        <div>
                            <div class="stars mb-2 text-warning">
                                @for (int s = 0; s < 5; s++)
                                {
                                    var fillStyle = s < t.Rating ? "font-variation-settings:'FILL' 1" : "font-variation-settings:'FILL' 0";
                                    <span class="material-symbols-outlined fs-6" style="@fillStyle">star</span>
                                }
                            </div>
                            <p class="fst-italic text-secondary small">&ldquo;@t.Message&rdquo;</p>
                        </div>
                        <div class="mt-3 pt-3 border-top">
                            <strong class="d-block text-dark">@t.DealerName</strong>
                            <span class="text-muted extra-small">@t.BusinessName @(!string.IsNullOrEmpty(t.City) ? $", {t.City}" : "")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- ===== FAQ Accordion ===== -->
@{
    var faqs = ViewBag.FAQs as IEnumerable<BRT.Models.FAQ>;
}
@if (faqs != null && faqs.Any())
{
    <section class="container my-5 py-4">
        <h3 class="fw-bold text-center mb-4 fade-in-up" style="color:var(--brt-green)">Frequently Asked Questions</h3>
        <div class="accordion accordion-flush max-w-800 mx-auto shadow-sm border rounded-3 overflow-hidden fade-in-up" id="faqAccordion">
            @{ int index = 0; }
            @foreach (var f in faqs)
            {
                index++;
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading@(index)">
                        <button class="accordion-button @(index > 1 ? "collapsed" : "") fw-semibold text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#faq@(index)" aria-expanded="@(index == 1 ? "true" : "false")" aria-controls="faq@(index)">
                            @f.Question
                        </button>
                    </h2>
                    <div id="faq@(index)" class="accordion-collapse collapse @(index == 1 ? "show" : "")" aria-labelledby="heading@(index)" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted small lh-lg">
                            @f.Answer
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- ===== Disclaimer Footer Ribbon ===== -->
<section class="container my-5 py-3">
    <div class="disclaimer-box p-3 rounded-3 bg-light border text-center d-flex flex-wrap justify-content-center align-items-center gap-3 gap-md-4 text-muted small fade-in-up">
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Bulk Orders Preferred</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Garlic Wholesale</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Grocery Wholesale</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Live Daily Market Rates</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Tax/GST Included</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined text-green fs-6">check_circle</span> Transport Extra</span>
    </div>
</section>
