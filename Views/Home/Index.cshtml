<!-- ===== Industries We Serve ===== -->
<section class="container my-5 py-4">
    <div class="text-center mb-5 fade-in-up">
        <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
            <span class="material-symbols-outlined fs-6">domain</span> INDUSTRIES WE SERVE
        </span>
        <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Commercial Clients &amp; Partners</h2>
    </div>
    <div class="row g-3 text-center">
        @{
            var industries = new[] {
                (Icon: "storefront", Name: "Supermarkets"),
                (Icon: "shopping_bag", Name: "Grocery Mandis"),
                (Icon: "local_mall", Name: "Retail Chains"),
                (Icon: "hotel", Name: "Hotels & Resorts"),
                (Icon: "flatware", Name: "Restaurants"),
                (Icon: "soup_kitchen", Name: "Catering Teams"),
                (Icon: "public", Name: "Exporters"),
                (Icon: "location_on", Name: "Pan-India Network")
            };
        }
        @foreach (var ind in industries)
        {
            <div class="col-6 col-md-3 fade-in-up">
                <div class="p-3 border rounded-4 bg-white shadow-sm hover-lift d-flex flex-column align-items-center justify-content-center h-100">
                    <span class="material-symbols-outlined text-green fs-3 mb-2">@ind.Icon</span>
                    <h6 class="fw-semibold mb-0 text-dark small">@ind.Name</h6>
                </div>
            </div>
        }
    </div>
</section>

