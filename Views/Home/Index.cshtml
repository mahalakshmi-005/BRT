@{
    ViewData["Title"] = "Home - B RAJ TRADERS";
}

<!-- ===== Announcement Bar ===== -->
<div class="announcement-bar py-2 text-white" style="background: var(--brt-green, #1b3b22); font-size: 0.875rem;">
    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="announcement-badges d-flex flex-wrap align-items-center gap-3">
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">verified</span> Premium Products
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">support_agent</span> Dedicated Support
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">workspace_premium</span> Trusted Business Partner
            </span>
        </div>
        <a href="tel:9865680694" class="text-white text-decoration-none fw-semibold d-inline-flex align-items-center gap-1">
            <span class="material-symbols-outlined fs-6 text-gold">call</span> +91 98656 80694
        </a>
    </div>
</div>

<!-- ===== Hero Section (Restored Original) ===== -->
<section class="hero-modern position-relative py-5 overflow-hidden">
    <div class="hero-inner container py-lg-4">
        <div class="hero-content fade-in-up is-visible max-w-700">
            <span class="hero-trust-badge d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill mb-3" style="background: rgba(212, 175, 55, 0.15); color: var(--brt-gold, #d4af37);">
                <span class="material-symbols-outlined fs-6">workspace_premium</span> Trusted Since 2000
            </span>
            <h1 class="display-4 fw-bold mb-2 text-uppercase tracking-tight">B RAJ TRADERS</h1>
            <p class="hero-tagline fs-5 text-muted mb-4">
                Garlic &amp; Grocery Commission Mandi<br class="d-none d-md-block" /> 
                <span class="fw-medium text-dark">Trusted Dealer-to-Dealer Wholesale Supplier</span>
            </p>

            <blockquote class="hero-quote border-start border-4 border-gold ps-3 py-1 my-4 fst-italic text-secondary">
                <span class="quote-mark fs-3 lh-1 align-middle text-gold">&ldquo;</span>
                Purity in every clove, trust in every deal.
                <span class="quote-mark fs-3 lh-1 align-middle text-gold">&rdquo;</span>
            </blockquote>

            <div class="hero-cta d-flex flex-wrap gap-3 mb-5">
                <a asp-controller="Order" asp-action="Request" class="btn btn-hero-gold px-4 py-2-5 shadow-sm fw-semibold">Request Wholesale Quote</a>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-hero-outline px-4 py-2-5 fw-semibold">Explore Products</a>
            </div>

            <div class="hero-inline-stats d-flex align-items-center gap-4 gap-md-5 pt-3 border-top">
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">25+</div>
                    <div class="stat-label text-muted small">Years Experience</div>
                </div>
                <div class="border-end h-100 opacity-25"></div>
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">500+</div>
                    <div class="stat-label text-muted small">Trusted Dealers</div>
                </div>
                <div class="border-end h-100 opacity-25"></div>
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">30+</div>
                    <div class="stat-label text-muted small">Product Varieties</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== Featured Products Showcase (Innovative Redesign) ===== -->
@{
    var featured = ViewBag.FeaturedProducts as List<BRT.Models.Product>;
}
@if (featured != null && featured.Any())
{
    <section class="container my-5 py-4">
        <div class="text-center mb-5 fade-in-up">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
                <span class="material-symbols-outlined fs-6">eco</span> OUR PRODUCTS
            </span>
            <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Premium Wholesale Selection</h2>
            <p class="text-muted mx-auto" style="max-width:600px">Top-tier mandi produce direct to distributors, hotels, and bulk retailers.</p>
        </div>
        <div class="row g-4">
            @foreach (var p in featured)
            {
                <div class="col-lg-4 col-md-6 fade-in-up">
                    <div class="card h-100 border-0 rounded-4 shadow-sm hover-lift overflow-hidden position-relative bg-white">
                        <div class="card-img-top bg-light text-center py-4 px-3 position-relative d-flex align-items-center justify-content-center" style="min-height: 220px; background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" class="img-fluid object-fit-contain hover-zoom" style="max-height: 180px;" />
                            }
                            else
                            {
                                <div class="avatar-icon-wrapper rounded-circle p-4 bg-white shadow-sm text-green">
                                    <span class="material-symbols-outlined display-4">
                                        @(p.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "shopping_cart_checkout")
                                    </span>
                                </div>
                            }
                            <span class="badge position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow-sm" style="background: var(--brt-green, #1b3b22); color: #fff; font-size: 0.75rem;">
                                @(p.SubCategory?.Name ?? "General")
                            </span>
                        </div>
                        
                        <div class="card-body d-flex flex-column p-4">
                            <h4 class="card-title h5 fw-bold mb-2 text-dark">
                                <span>@p.Name</span>
                                @if (!string.IsNullOrEmpty(p.NameTamil))
                                {
                                    <small class="d-block text-muted fw-normal fs-6 mt-1">@p.NameTamil</small>
                                }
                            </h4>
                            <p class="card-text text-muted small flex-grow-1 lh-base">
                                @(string.IsNullOrEmpty(p.Description) ? "Standard commercial bulk packaging available with guaranteed fresh supply." : p.Description)
                            </p>
                            
                            <div class="pt-3 mt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-light text-success border border-success-subtle px-2 py-1">In Stock</span>
                                <a asp-controller="Catalog" asp-action="Product" asp-route-slug="@p.Slug" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-semibold d-inline-flex align-items-center gap-1">
                                    View Details <span class="material-symbols-outlined fs-6">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5 fade-in-up">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-brt-gold px-4 py-2-5 shadow-sm fw-semibold rounded-pill">View Full Catalog</a>
        </div>
    </section>
}

<!-- ===== Live Market Dashboard ===== -->
@{
    var dashboard = ViewBag.MarketDashboard as List<BRT.Models.MarketPrice>;
}
<section class="container my-5 py-4">
    <div class="p-4 p-md-5 rounded-4 shadow-sm border fade-in-up" style="background: linear-gradient(180deg, #ffffff 0%, #f9fbf9 100%);">
        <div class="text-center mb-5">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
                <span class="material-symbols-outlined fs-6">trending_up</span> LIVE MARKET
            </span>
            <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Today's Mandi Wholesale Rates</h2>
            <p class="text-muted mx-auto mb-0" style="max-width:600px">Daily updated prices direct from regional suppliers.</p>
        </div>
        <div class="row g-3">
            @if (dashboard != null && dashboard.Any())
            {
                foreach (var m in dashboard)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <div class="p-3 rounded-4 border bg-white h-100 d-flex flex-column justify-content-between shadow-sm hover-lift">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="p-2 rounded-circle bg-light text-gold d-inline-flex align-items-center">
                                        <span class="material-symbols-outlined fs-5">
                                            @(m.Product?.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "shopping_bag")
                                        </span>
                                    </span>
                                    <span class="badge bg-success-subtle text-success extra-small fw-semibold">Live</span>
                                </div>
                                <h6 class="fw-bold mb-0 text-dark text-truncate">@m.Product?.Name</h6>
                                <span class="text-muted extra-small d-block mb-2">@m.Product?.NameTamil</span>
                            </div>
                            <div class="mt-2 pt-2 border-top">
                                <div class="fs-5 fw-bold text-green">₹@m.TodayPrice.ToString("N2") <span class="fs-7 text-muted fw-normal">/ unit</span></div>
                                <div class="d-flex justify-content-between align-items-center mt-1 text-muted extra-small">
                                    <span>Updated Today</span>
                                    <span class="material-symbols-outlined text-gold" style="font-size: 0.85rem">verified</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            <div class="col-lg-3 col-md-4 col-12">
                <div class="p-4 rounded-4 border h-100 text-center d-flex flex-column align-items-center justify-content-center text-white shadow-sm" style="background: linear-gradient(135deg, var(--brt-green, #1b3b22), #2a5233);">
                    <span class="material-symbols-outlined display-6 mb-2 text-gold">forum</span>
                    <h6 class="fw-bold mb-1">Custom Bulk Rate?</h6>
                    <p class="extra-small mb-3 opacity-75">Connect directly with our desk for custom orders.</p>
                    <a asp-controller="Order" asp-action="Request" class="btn btn-sm btn-hero-gold px-3 rounded-pill fw-semibold">Get Quotation</a>
                </div>
            </div>
        </div>
    </div>
</section>

