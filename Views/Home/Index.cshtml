                                    <span class="badge bg-danger text-white extra-small fw-semibold pulse-badge">LIVE</span>
                                </div>
                                <h6 class="fw-bold mb-0 text-dark text-truncate">@m.Product?.Name</h6>
                                <span class="text-muted extra-small d-block mb-2">@m.Product?.NameTamil</span>
                            </div>
                            <div class="mt-2 pt-2 border-top">
                                <div class="fs-5 fw-bold text-green">₹@m.TodayPrice.ToString("N2") <span class="fs-7 text-muted fw-normal">/ unit</span></div>
                                <div class="d-flex justify-content-between align-items-center mt-1 text-muted extra-small">
