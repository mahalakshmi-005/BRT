@{
    ViewData["Title"] = "Home - B RAJ TRADERS";
}

<!-- ===== Modern Corporate Color Palette & Fixed Equal Height Styles ===== -->
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300..900;1,300..900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        /* ===== Trading Ledger Hero Palette (premium, subject-specific) ===== */
        --brt-ink: #1B2430;              /* deep ink text */
        --brt-ink-soft: #4A5568;         /* muted ink for body copy */
        --brt-paper: #F7F3EA;            /* warm ledger paper */
        --brt-paper-line: rgba(27, 36, 48, 0.14);
        --brt-ledger-green: #2F5D50;     /* deep trading green */
        --brt-ledger-green-deep: #234A40;
        --brt-trader-gold: #B4842A;      /* muted premium gold, not bright amber */
        --brt-trader-gold-soft: rgba(180, 132, 42, 0.14);

        /* Legacy hero tokens kept for anything else referencing them */
        --brt-hero-green: #2F5D50;
        --brt-hero-emerald: #3F7A68;
        --brt-hero-mint: #EDE9DD;

        /* Rest of Page Corporate Theme (unchanged) */
        --brt-navy: #0F172A;
        --brt-navy-light: #1E293B;
        --brt-amber: #D97706;
        --brt-gold: #F59E0B;
        --brt-gold-glow: rgba(245, 158, 11, 0.25);
        --brt-card-bg: #FFFFFF;
    }

    /* Keyframe Animations Escaped for Razor (@@) */
    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-6px); }
    }

    @@keyframes pulseGlow {
        0% { box-shadow: 0 0 0 0 rgba(217, 119, 6, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(217, 119, 6, 0); }
        100% { box-shadow: 0 0 0 0 rgba(217, 119, 6, 0); }
    }

    /* Uniform Height Grid & Card Fixes */
    .row-equal-height {
        display: flex;
        flex-wrap: wrap;
    }

    .row-equal-height > [class*='col-'] {
        display: flex;
        flex-direction: column;
    }

    /* Innovative Base Cards */
    .innovative-card {
        background: var(--brt-card-bg);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
        width: 100%;
    }

    .innovative-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
        transition: 0.6s;
        z-index: 2;
        pointer-events: none;
    }

    .innovative-card:hover::before {
        left: 200%;
    }

    .innovative-card:hover {
        transform: translateY(-8px);
        border-color: var(--brt-gold) !important;
        box-shadow: 0 20px 35px rgba(15, 23, 42, 0.1), 0 0 15px var(--brt-gold-glow) !important;
    }

    /* Floating Icon Animation */
    .anim-float-icon {
        animation: floatIcon 3.5s ease-in-out infinite;
        display: inline-block;
    }

    /* Pulse Badge Animation */
    .pulse-badge {
        animation: pulseGlow 2s infinite;
    }

    /* Portfolio Hero Bento Cards (Strict Equal Height) */
    .portfolio-card-hero {
        border-radius: 24px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        z-index: 1;
        width: 100%;
        min-height: 250px;
    }

    .portfolio-card-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(245, 158, 11, 0.15), transparent 70%);
        z-index: 0;
    }

    .portfolio-card-hero:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 45px rgba(15, 23, 42, 0.3);
    }

    .portfolio-card-hero:hover .arrow-icon {
        transform: translateX(8px);
    }

    .arrow-icon {
        transition: transform 0.3s ease;
    }

    /* Image Container Zoom */
    .img-zoom-container {
        overflow: hidden;
        border-radius: 16px;
    }

    .img-zoom-container img {
        transition: transform 0.5s ease;
    }

    .innovative-card:hover .img-zoom-container img {
        transform: scale(1.08);
    }

    /* Dynamic Buttons (non-hero, unchanged) */
    .btn-brt-hero-green {
        background: var(--brt-ledger-green);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-hero-green:hover {
        background: var(--brt-ledger-green-deep);
        color: #FFFFFF;
        box-shadow: 0 8px 20px rgba(47, 93, 80, 0.3);
    }

    .btn-brt-primary {
        background: var(--brt-navy);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-primary:hover {
        background: var(--brt-navy-light);
        color: var(--brt-gold);
    }

    .btn-brt-amber {
        background: var(--brt-amber);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-amber:hover {
        background: #B45309;
        color: #FFFFFF;
    }

    .text-navy { color: var(--brt-navy) !important; }
    .text-amber { color: var(--brt-amber) !important; }
    .text-hero-green { color: var(--brt-ledger-green) !important; }
    .bg-navy { background-color: var(--brt-navy) !important; }
    .extra-small { font-size: 0.78rem; }
    .bg-glass {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    /* ===================================================================
       LEDGER HERO — signature element: the hero reads like a trading
       manifest / grading certificate rather than a generic SaaS hero.
       =================================================================== */
    .ledger-hero {
        background:
            linear-gradient(180deg, var(--brt-paper) 0%, #FBF9F4 100%);
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--brt-paper-line);
    }

    .ledger-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
            180deg,
            transparent 0px,
            transparent 38px,
            var(--brt-paper-line) 39px
        );
        opacity: 0.5;
        pointer-events: none;
    }

    .ledger-stamp-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(180, 132, 42, 0.45);
        background: var(--brt-trader-gold-soft);
        color: var(--brt-trader-gold);
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 7px 14px;
        border-radius: 3px;
    }

    .ledger-stamp-badge .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--brt-trader-gold);
        flex-shrink: 0;
    }

    .ledger-headline {
        font-family: 'Fraunces', serif;
        font-weight: 600;
        font-size: 3.4rem;
        letter-spacing: -0.5px;
        line-height: 1.05;
        color: var(--brt-ink);
        margin: 18px 0 14px 0;
    }

    .ledger-headline .accent-word {
        color: var(--brt-trader-gold);
        font-style: italic;
        font-weight: 500;
    }

    .ledger-subtitle {
        font-size: 1.08rem;
        color: var(--brt-ink-soft);
        max-width: 480px;
        line-height: 1.6;
        margin-bottom: 0;
    }

    .ledger-subtitle strong {
        color: var(--brt-ink);
        font-weight: 700;
    }

    .ledger-quote {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 1.15rem;
        color: var(--brt-ink-soft);
        border-left: 3px solid var(--brt-trader-gold);
        padding: 4px 0 4px 18px;
        margin: 28px 0;
    }

    .ledger-quote .quote-mark {
        color: var(--brt-trader-gold);
        font-family: 'Fraunces', serif;
        font-style: normal;
    }

    /* CTA — two buttons, deliberately side by side, unmistakably premium */
    .ledger-cta-row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 36px;
    }

    .btn-ledger-primary {
        background: var(--brt-ledger-green);
        color: #FFFFFF !important;
        border: 1px solid var(--brt-ledger-green);
        padding: 14px 28px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.92rem;
        letter-spacing: 0.3px;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 24px rgba(47, 93, 80, 0.22);
    }

    .btn-ledger-primary:hover {
        background: var(--brt-ledger-green-deep);
        border-color: var(--brt-ledger-green-deep);
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(47, 93, 80, 0.3);
        color: #FFFFFF !important;
    }

    .btn-ledger-outline {
        background: transparent;
        color: var(--brt-ink) !important;
        border: 1px solid rgba(27, 36, 48, 0.35);
        padding: 14px 28px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.92rem;
        letter-spacing: 0.3px;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-ledger-outline:hover {
        border-color: var(--brt-ink);
        background: rgba(27, 36, 48, 0.04);
        transform: translateY(-2px);
        color: var(--brt-ink) !important;
    }

    /* Manifest / ledger stat strip — figures as data, not decoration */
    .ledger-manifest {
        border-top: 1px solid var(--brt-paper-line);
        padding-top: 20px;
        display: flex;
        gap: 32px;
        flex-wrap: wrap;
    }

    .ledger-manifest-item {
        display: flex;
        flex-direction: column;
    }

    .ledger-manifest-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 1.7rem;
        font-weight: 600;
        color: var(--brt-ink);
        line-height: 1;
    }

    .ledger-manifest-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--brt-ink-soft);
        margin-top: 6px;
    }

    /* Certificate-style image frame on the right */
    .ledger-cert-frame {
        position: relative;
        display: inline-block;
        padding: 14px;
        background: #FFFFFF;
        border: 1px solid var(--brt-paper-line);
        border-radius: 6px;
        box-shadow: 0 30px 60px -20px rgba(27, 36, 48, 0.25);
    }

    .ledger-cert-frame::before {
        content: '';
        position: absolute;
        inset: 14px -10px -10px 14px;
        background: var(--brt-paper);
        border: 1px solid var(--brt-paper-line);
        border-radius: 6px;
        z-index: -1;
    }

    .ledger-cert-frame img {
        display: block;
        border-radius: 3px;
        max-height: 400px;
        width: 100%;
        object-fit: cover;
        border: 1px solid rgba(27, 36, 48, 0.08);
    }

    .ledger-seal {
        position: absolute;
        width: 92px;
        height: 92px;
        border-radius: 50%;
        border: 1.5px dashed var(--brt-trader-gold);
        background: #FFFFFF;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        box-shadow: 0 8px 20px rgba(27, 36, 48, 0.15);
    }

    .ledger-seal .material-symbols-outlined {
        color: var(--brt-ledger-green);
        font-size: 1.3rem;
    }

    .ledger-seal span.seal-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.56rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--brt-ink);
        font-weight: 600;
        margin-top: 2px;
        line-height: 1.2;
    }

    .ledger-seal-top {
        top: -18px;
        left: -18px;
    }

    .ledger-seal-bottom {
        bottom: -18px;
        right: -28px;
        background: var(--brt-navy);
        border-color: var(--brt-trader-gold);
    }

    .ledger-seal-bottom .material-symbols-outlined,
    .ledger-seal-bottom span.seal-label {
        color: #FFFFFF;
    }

    @@media (max-width: 991px) {
        .ledger-headline { font-size: 2.5rem; }
        .ledger-cert-frame { margin-top: 40px; }
    }

    @@media (max-width: 576px) {
        .ledger-headline { font-size: 2.1rem; }
        .ledger-manifest { gap: 22px; }
        .ledger-seal { width: 74px; height: 74px; }
    }
</style>

<!-- ===== Announcement Bar ===== -->
<div class="announcement-bar py-2 text-white" style="background: var(--brt-navy); font-size: 0.875rem;">
    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="announcement-badges d-flex flex-wrap align-items-center gap-3">
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-amber">verified</span> Premium Products
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-amber">support_agent</span> Dedicated Support
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-amber">workspace_premium</span> Trusted Business Partner
            </span>
        </div>
        <a href="tel:9865680694" class="text-white text-decoration-none fw-semibold d-inline-flex align-items-center gap-1">
            <span class="material-symbols-outlined fs-6 text-amber">call</span> +91 98656 80694
        </a>
    </div>
</div>

<!-- ===== Ledger / Trading-Manifest Hero Section ===== -->
<section class="ledger-hero py-5">
    <div class="container py-lg-4 position-relative">
        <div class="row align-items-center g-5">

            <!-- Left Column: Content -->
            <div class="col-lg-6 fade-in-up is-visible">

                <span class="ledger-stamp-badge">
                    <span class="dot"></span> Est. 2000 &middot; Direct Mandi Trading
                </span>

                <h1 class="ledger-headline">
                    B RAJ<br /><span class="accent-word">Traders</span>
                </h1>

                <p class="ledger-subtitle">
                    <strong>Garlic &amp; grocery commission mandi</strong> — dealer-to-dealer wholesale supply, graded and priced the way a trading floor should be.
                </p>

                <blockquote class="ledger-quote">
                    <span class="quote-mark">&ldquo;</span>Purity in every clove, trust in every deal.<span class="quote-mark">&rdquo;</span>
                </blockquote>

                <div class="ledger-cta-row">
                    <a asp-controller="Order" asp-action="Request" class="btn-ledger-primary">
                        Request Wholesale Quote <span class="material-symbols-outlined" style="font-size:1.1rem">arrow_forward</span>
                    </a>
                    <a asp-controller="Catalog" asp-action="Index" class="btn-ledger-outline">
                        Explore Products
                    </a>
                </div>

                <div class="ledger-manifest">
                    <div class="ledger-manifest-item">
                        <span class="ledger-manifest-num">25+</span>
                        <span class="ledger-manifest-label">Years Trading</span>
                    </div>
                    <div class="ledger-manifest-item">
                        <span class="ledger-manifest-num">500+</span>
                        <span class="ledger-manifest-label">Dealer Network</span>
                    </div>
                    <div class="ledger-manifest-item">
                        <span class="ledger-manifest-num">30+</span>
                        <span class="ledger-manifest-label">Product Varieties</span>
                    </div>
                </div>
            </div>

            <!-- Right Column: Certificate-style Hero Image -->
            <div class="col-lg-6 text-center fade-in-up">
                <div class="ledger-cert-frame d-inline-block position-relative">
                    <img src="~/images/hero.png" alt="Garlic Mandi Wholesale"
                         onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1618160702438-9b02ab6515c9?auto=format&fit=crop&w=800&q=80';" />

                    <div class="ledger-seal ledger-seal-top d-none d-sm-flex">
                        <span class="material-symbols-outlined">verified</span>
                        <span class="seal-label">100%<br />Quality</span>
                    </div>

                    <div class="ledger-seal ledger-seal-bottom d-none d-sm-flex">
                        <span class="material-symbols-outlined">local_shipping</span>
                        <span class="seal-label">Fast<br />Dispatch</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- ===== Featured Products Showcase ===== -->
@{
    var featured = ViewBag.FeaturedProducts as List<BRT.Models.Product>;
}
@if (featured != null && featured.Any())
{
    <section class="container my-5 py-4">
        <div class="text-center mb-5 fade-in-up">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1 text-amber">
                <span class="material-symbols-outlined fs-6 anim-float-icon">workspace_premium</span> OUR PRODUCTS
            </span>
            <h2 class="fw-bold mt-2 text-navy">Premium Wholesale Selection</h2>
            <p class="text-muted mx-auto" style="max-width:600px">Top-tier mandi produce direct to distributors, hotels, and bulk retailers.</p>
        </div>
        <div class="row g-4 row-equal-height">
            @foreach (var p in featured)
            {
                <div class="col-lg-4 col-md-6 fade-in-up">
                    <div class="innovative-card p-3 d-flex flex-column justify-content-between h-100">
                        <div>
                            <div class="img-zoom-container bg-light text-center py-4 px-3 position-relative d-flex align-items-center justify-content-center" style="min-height: 200px; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" class="img-fluid object-fit-contain" style="max-height: 170px;" />
                                }
                                else
                                {
                                    <div class="rounded-circle p-4 bg-white shadow-sm text-navy anim-float-icon">
                                        <span class="material-symbols-outlined display-4">
                                            @(p.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "shopping_cart_checkout")
                                        </span>
                                    </div>
                                }
                                <span class="badge position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow-sm bg-navy text-white" style="font-size: 0.75rem;">
                                    @(p.SubCategory?.Name ?? "General")
                                </span>
                            </div>

                            <div class="pt-3 px-2">
                                <h4 class="card-title h5 fw-bold mb-1 text-navy">
                                    <span>@p.Name</span>
                                </h4>
                                @if (!string.IsNullOrEmpty(p.NameTamil))
                                {
                                    <span class="d-block text-muted small fw-medium mb-2">@p.NameTamil</span>
                                }
                                <p class="card-text text-muted small lh-base">
                                    @(string.IsNullOrEmpty(p.Description) ? "Standard commercial bulk packaging available with fresh mandi stock." : p.Description)
                                </p>
                            </div>
                        </div>

                        <div class="pt-3 px-2 mt-3 border-top d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark border px-2-5 py-1 rounded-pill extra-small fw-semibold">
                                Fresh Stock
                            </span>
                            <a asp-controller="Catalog" asp-action="Product" asp-route-slug="@p.Slug" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-semibold d-inline-flex align-items-center gap-1">
                                Details <span class="material-symbols-outlined fs-6 arrow-icon">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5 fade-in-up">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-brt-primary px-4 py-2-5 shadow-sm fw-semibold rounded-pill">View Full Catalog</a>
        </div>
    </section>
}

<!-- ===== Live Market Dashboard ===== -->
@{
    var dashboard = ViewBag.MarketDashboard as List<BRT.Models.MarketPrice>;
}
<section class="container my-5 py-4">
    <div class="p-4 p-md-5 rounded-4 shadow-sm border fade-in-up" style="background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);">
        <div class="text-center mb-5">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1 text-amber">
                <span class="material-symbols-outlined fs-6 anim-float-icon">trending_up</span> LIVE MARKET
            </span>
            <h2 class="fw-bold mt-2 text-navy">Today's Mandi Wholesale Rates</h2>
            <p class="text-muted mx-auto mb-0" style="max-width:600px">Daily updated rates directly synchronized with mandi markets.</p>
        </div>
        <div class="row g-3 row-equal-height">
            @if (dashboard != null && dashboard.Any())
            {
                foreach (var m in dashboard)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <div class="innovative-card p-3 h-100 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="p-2 rounded-circle bg-light text-amber d-inline-flex align-items-center anim-float-icon">
                                        <span class="material-symbols-outlined fs-5">
                                            @(m.Product?.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "shopping_cart_checkout")
                                        </span>
                                    </span>
                                    <span class="badge bg-danger text-white extra-small fw-semibold pulse-badge">LIVE</span>
                                </div>
                                <h6 class="fw-bold mb-0 text-navy text-truncate">@m.Product?.Name</h6>
                                <span class="text-muted extra-small d-block mb-2">@m.Product?.NameTamil</span>
                            </div>
                            <div class="mt-2 pt-2 border-top">
                                <div class="fs-5 fw-bold text-navy">₹@m.TodayPrice.ToString("N2") <span class="fs-7 text-muted fw-normal">/ unit</span></div>
                                <div class="d-flex justify-content-between align-items-center mt-1 text-muted extra-small">
                                    <span>Updated Today</span>
                                    <span class="material-symbols-outlined text-amber" style="font-size: 0.85rem">verified</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            <div class="col-lg-3 col-md-4 col-12">
