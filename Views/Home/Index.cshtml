<!-- ===== Premium Products Showcase ===== -->
@{
    var featured = (List<BRT.Models.Product>)ViewBag.FeaturedProducts;
}
@if (featured != null && featured.Any())
{
    <section class="container my-5 py-3">
        <div class="text-center mb-5 fade-in-up">
            <span class="hero-eyebrow" style="color:var(--brt-gold)"><span class="material-symbols-outlined">eco</span> OUR PRODUCTS</span>
            <h2 class="mt-2" style="color:var(--brt-green)">Premium Wholesale Products</h2>
            <p class="text-muted mx-auto" style="max-width:600px">High quality garlic and grocery products directly supplied for wholesale buyers, supermarkets, hotels and distributors.</p>
        </div>
        <div class="row g-4">
            @foreach (var p in featured)
            {
                <div class="col-md-4 fade-in-up">
                    <div class="premium-card">
                        <div class="premium-card-media">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined">@(p.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "restaurant")</span>
                            }
                        </div>
                        <div class="premium-card-body">
                            <span class="premium-card-tag">@p.SubCategory?.Name</span>
                            <h4>
                                <span class="lang-en-text">@p.Name</span>
                                @if (!string.IsNullOrEmpty(p.NameTamil))
                                {
                                    <span class="lang-ta-text">@p.NameTamil</span>
                                }
                            </h4>
                            <p>@(string.IsNullOrEmpty(p.Description) ? "Premium quality, available in bulk wholesale packing." : p.Description)</p>
                            <div class="premium-card-footer">
                                <span class="text-muted small">Bulk Orders</span>
                                <a asp-controller="Catalog" asp-action="Product" asp-route-slug="@p.Slug">View <span class="material-symbols-outlined" style="font-size:1rem">arrow_forward</span></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4 fade-in-up">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-brt-gold">View More Products</a>
        </div>
    </section>
}

<!-- ===== Live Market Dashboard ===== -->
@{
    var dashboard = (List<BRT.Models.MarketPrice>)ViewBag.MarketDashboard;
}
<section class="container my-5 py-3">
    <div class="market-dashboard-section fade-in-up">
        <div class="text-center mb-5">
            <span class="hero-eyebrow" style="color:var(--brt-gold)"><span class="material-symbols-outlined">trending_up</span> LIVE MARKET</span>
            <h2 class="mt-2" style="color:var(--brt-green)">Today's Wholesale Market</h2>
            <p class="text-muted mx-auto" style="max-width:600px">Prices are updated daily. Final quotation will be confirmed by our team before dispatch.</p>
        </div>
        <div class="row g-4">
            @if (dashboard != null && dashboard.Any())
            {
                foreach (var m in dashboard)
                {
                    <div class="col-md-3 col-6">
                        <div class="market-card">
                            <div class="market-card-icon"><span class="material-symbols-outlined">@(m.Product!.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "restaurant")</span></div>
                            <h5>@m.Product.Name</h5>
                            <small>₹@m.TodayPrice.ToString("F2") / unit</small>
                            <div class="market-card-footer">
                                <span>Updated Today</span>
                                <span class="material-symbols-outlined" style="font-size:1rem;color:var(--brt-gold)">verified</span>
                            </div>
                        </div>
                    </div>
                }
            }
            <div class="col-md-3 col-6">
                <div class="market-card market-cta">
                    <span class="material-symbols-outlined" style="font-size:2rem;margin-bottom:0.6rem">forum</span>
                    <h5>Need Today's Price?</h5>
                    <p class="small">Contact our team for live wholesale quotation.</p>
                    <a asp-controller="Order" asp-action="Request" class="btn btn-sm btn-hero-gold mt-2">Request Quote</a>
                </div>
            </div>
        </div>
    </div>
</section>

