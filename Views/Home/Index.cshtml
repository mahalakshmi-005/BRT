@{
    ViewData["Title"] = "Home - B RAJ TRADERS";
}

<!-- ===== Announcement Bar ===== -->
<div class="announcement-bar py-2 text-white" style="background: var(--brt-green, #1b3b22); font-size: 0.875rem;">
    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="announcement-badges d-flex flex-wrap align-items-center gap-3">
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">verified</span> Premium Products
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">support_agent</span> Dedicated Support
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6 text-gold">workspace_premium</span> Trusted Business Partner
            </span>
        </div>
        <a href="tel:9865680694" class="text-white text-decoration-none fw-semibold d-inline-flex align-items-center gap-1">
            <span class="material-symbols-outlined fs-6 text-gold">call</span> +91 98656 80694
        </a>
    </div>
</div>

<!-- ===== Hero Section ===== -->
<section class="hero-modern position-relative py-5 overflow-hidden">
    <div class="hero-inner container py-lg-4">
        <div class="hero-content fade-in-up is-visible max-w-700">
            <span class="hero-trust-badge d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill mb-3" style="background: rgba(212, 175, 55, 0.15); color: var(--brt-gold, #d4af37);">
                <span class="material-symbols-outlined fs-6">workspace_premium</span> Trusted Since 2000
            </span>
            <h1 class="display-4 fw-bold mb-2 text-uppercase tracking-tight">B RAJ TRADERS</h1>
            <p class="hero-tagline fs-5 text-muted mb-4">
                Garlic &amp; Grocery Commission Mandi<br class="d-none d-md-block" /> 
                <span class="fw-medium text-dark">Trusted Dealer-to-Dealer Wholesale Supplier</span>
            </p>

            <blockquote class="hero-quote border-start border-4 border-gold ps-3 py-1 my-4 fst-italic text-secondary">
                <span class="quote-mark fs-3 lh-1 align-middle text-gold">&ldquo;</span>
                Purity in every clove, trust in every deal.
                <span class="quote-mark fs-3 lh-1 align-middle text-gold">&rdquo;</span>
            </blockquote>

            <div class="hero-cta d-flex flex-wrap gap-3 mb-5">
                <a asp-controller="Order" asp-action="Request" class="btn btn-hero-gold px-4 py-2-5 shadow-sm fw-semibold">Request Wholesale Quote</a>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-hero-outline px-4 py-2-5 fw-semibold">Explore Products</a>
            </div>

            <div class="hero-inline-stats d-flex align-items-center gap-4 gap-md-5 pt-3 border-top">
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">25+</div>
                    <div class="stat-label text-muted small">Years Experience</div>
                </div>
                <div class="border-end h-100 opacity-25"></div>
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">500+</div>
                    <div class="stat-label text-muted small">Trusted Dealers</div>
                </div>
                <div class="border-end h-100 opacity-25"></div>
                <div>
                    <div class="stat-num fw-bold fs-3 text-green">30+</div>
                    <div class="stat-label text-muted small">Product Varieties</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== Featured Products Showcase ===== -->
@{
    var featured = ViewBag.FeaturedProducts as List<BRT.Models.Product>;
}
@if (featured != null && featured.Any())
{
    <section class="container my-5 py-4">
        <div class="text-center mb-5 fade-in-up">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
                <span class="material-symbols-outlined fs-6">eco</span> OUR PRODUCTS
            </span>
            <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Premium Wholesale Products</h2>
            <p class="text-muted mx-auto" style="max-width:600px">High-quality garlic and grocery products directly supplied for wholesale buyers, supermarkets, hotels, and distributors.</p>
        </div>
        <div class="row g-4">
            @foreach (var p in featured)
            {
                <div class="col-lg-4 col-md-6 fade-in-up">
                    <div class="premium-card h-100 card border-0 shadow-sm hover-lift rounded-3 overflow-hidden">
                        <div class="premium-card-media position-relative bg-light text-center py-4">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" class="img-fluid object-fit-cover" style="max-height: 220px;" />
                            }
                            else
                            {
                                <div class="p-4 text-muted">
                                    <span class="material-symbols-outlined display-1">
                                        @(p.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "restaurant")
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="premium-card-body card-body d-flex flex-column p-4">
                            <span class="premium-card-tag badge bg-light text-dark border align-self-start mb-2 fw-normal">
                                @(p.SubCategory?.Name ?? "General")
                            </span>
                            <h4 class="card-title h5 fw-bold mb-2">
                                <span class="lang-en-text">@p.Name</span>
                                <span class="lang-ta-text ms-1 text-muted fw-normal fs-6">@(!string.IsNullOrEmpty(p.NameTamil) ? $"({p.NameTamil})" : "")</span>
                            </h4>
                            <p class="card-text text-muted small flex-grow-1">
                                @(string.IsNullOrEmpty(p.Description) ? "Premium quality, available in bulk wholesale packing." : p.Description)
                            </p>
                            <div class="premium-card-footer pt-3 mt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-medium">Bulk Orders Only</span>
                                <a asp-controller="Catalog" asp-action="Product" asp-route-slug="@p.Slug" class="text-decoration-none fw-semibold d-inline-flex align-items-center gap-1 text-green">
                                    View Details <span class="material-symbols-outlined fs-6">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5 fade-in-up">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-brt-gold px-4 py-2-5 shadow-sm fw-semibold">View Full Catalog</a>
        </div>
    </section>
}

<!-- ===== Live Market Dashboard ===== -->
@{
    var dashboard = ViewBag.MarketDashboard as List<BRT.Models.MarketPrice>;
}
<section class="container my-5 py-4">
    <div class="market-dashboard-section p-4 p-md-5 rounded-4 shadow-sm bg-white border fade-in-up">
        <div class="text-center mb-5">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
                <span class="material-symbols-outlined fs-6">trending_up</span> LIVE MARKET
            </span>
            <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Today's Wholesale Rates</h2>
            <p class="text-muted mx-auto mb-0" style="max-width:600px">Prices are updated daily based on mandi rates. Final quotation will be confirmed before dispatch.</p>
        </div>
        <div class="row g-3">
            @if (dashboard != null && dashboard.Any())
            {
                foreach (var m in dashboard)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <div class="market-card p-3 rounded-3 border bg-light h-100 d-flex flex-column justify-content-between">
                            <div>
                                <div class="market-card-icon mb-2 text-gold">
                                    <span class="material-symbols-outlined">
                                        @(m.Product?.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "restaurant")
                                    </span>
                                </div>
                                <h6 class="fw-bold mb-1 text-truncate">
                                    <span class="lang-en-text">@m.Product?.Name</span>
                                    <span class="lang-ta-text d-block text-muted small fw-normal">@m.Product?.NameTamil</span>
                                </h6>
                            </div>
                            <div class="mt-3">
                                <div class="fs-5 fw-bold text-green">₹@m.TodayPrice.ToString("N2") <span class="fs-7 text-muted fw-normal">/ unit</span></div>
                                <div class="market-card-footer d-flex justify-content-between align-items-center mt-2 pt-2 border-top text-muted extra-small">
                                    <span>Updated Today</span>
                                    <span class="material-symbols-outlined text-gold" style="font-size: 0.9rem">verified</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            <div class="col-lg-3 col-md-4 col-12">
                <div class="market-card market-cta p-3 rounded-3 border h-100 text-center d-flex flex-column align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, var(--brt-green, #1b3b22), #2a5233);">
                    <span class="material-symbols-outlined display-6 mb-2 text-gold">forum</span>
                    <h6 class="fw-bold mb-1">Need Custom Quotation?</h6>
                    <p class="extra-small mb-3 opacity-75">Get live bulk rates directly on WhatsApp or Call.</p>
                    <a asp-controller="Order" asp-action="Request" class="btn btn-sm btn-hero-gold px-3 fw-semibold">Request Quote</a>
                </div>
            </div>
        </div>
    </div>
</section>

