<!-- ===== Modern Corporate Color Palette & Fixed Equal Height Styles ===== -->
<style>
    :root {
        /* Hero Section Green Theme */
        --brt-hero-green: #059669;
        --brt-hero-emerald: #10B981;
        --brt-hero-mint: #D1FAE5;
        
        /* Rest of Page Corporate Theme (No Green Text/Buttons) */
        --brt-navy: #0F172A;
        --brt-navy-light: #1E293B;
        --brt-amber: #D97706;
        --brt-gold: #F59E0B;
        --brt-gold-glow: rgba(245, 158, 11, 0.25);
        --brt-card-bg: #FFFFFF;
    }

    /* Keyframe Animations Escaped for Razor (@@) */
    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-6px); }
    }

    @@keyframes pulseGlow {
        0% { box-shadow: 0 0 0 0 rgba(217, 119, 6, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(217, 119, 6, 0); }
        100% { box-shadow: 0 0 0 0 rgba(217, 119, 6, 0); }
    }

    /* Uniform Height Grid & Card Fixes */
    .row-equal-height {
        display: flex;
        flex-wrap: wrap;
    }

    .row-equal-height > [class*='col-'] {
        display: flex;
        flex-direction: column;
    }

    /* Innovative Base Cards */
    .innovative-card {
        background: var(--brt-card-bg);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
        width: 100%;
    }

    .innovative-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
        transition: 0.6s;
        z-index: 2;
        pointer-events: none;
    }

    .innovative-card:hover::before {
        left: 200%;
    }

    .innovative-card:hover {
        transform: translateY(-8px);
        border-color: var(--brt-gold) !important;
        box-shadow: 0 20px 35px rgba(15, 23, 42, 0.1), 0 0 15px var(--brt-gold-glow) !important;
    }

    /* Floating Icon Animation */
    .anim-float-icon {
        animation: floatIcon 3.5s ease-in-out infinite;
        display: inline-block;
    }

    /* Pulse Badge Animation */
    .pulse-badge {
        animation: pulseGlow 2s infinite;
    }

    /* Portfolio Hero Bento Cards (Strict Equal Height) */
    .portfolio-card-hero {
        border-radius: 24px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        z-index: 1;
        width: 100%;
        min-height: 250px;
    }

    .portfolio-card-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(245, 158, 11, 0.15), transparent 70%);
        z-index: 0;
    }

    .portfolio-card-hero:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 45px rgba(15, 23, 42, 0.3);
    }

    .portfolio-card-hero:hover .arrow-icon {
        transform: translateX(8px);
    }

    .arrow-icon {
        transition: transform 0.3s ease;
    }

    /* Image Container Zoom */
    .img-zoom-container {
        overflow: hidden;
        border-radius: 16px;
    }

    .img-zoom-container img {
        transition: transform 0.5s ease;
    }

    .innovative-card:hover .img-zoom-container img {
        transform: scale(1.08);
    }

    /* Dynamic Buttons */
    .btn-brt-hero-green {
        background: var(--brt-hero-green);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-hero-green:hover {
        background: #047857;
        color: #FFFFFF;
        box-shadow: 0 8px 20px rgba(5, 150, 105, 0.3);
    }

    .btn-brt-primary {
        background: var(--brt-navy);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-primary:hover {
        background: var(--brt-navy-light);
        color: var(--brt-gold);
    }

    .btn-brt-amber {
        background: var(--brt-amber);
        color: #FFFFFF;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-brt-amber:hover {
        background: #B45309;
        color: #FFFFFF;
    }

    .text-navy { color: var(--brt-navy) !important; }
    .text-amber { color: var(--brt-amber) !important; }
    .text-hero-green { color: var(--brt-hero-green) !important; }
    .bg-navy { background-color: var(--brt-navy) !important; }
    .extra-small { font-size: 0.78rem; }
    .bg-glass {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }
</style>

