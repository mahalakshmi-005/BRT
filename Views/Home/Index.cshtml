<!-- ===== Featured Products Showcase (Animated Cards) ===== -->
@{
    var featured = ViewBag.FeaturedProducts as List<BRT.Models.Product>;
}
@if (featured != null && featured.Any())
{
    <section class="container my-5 py-4">
        <div class="text-center mb-5 fade-in-up">
            <span class="hero-eyebrow fw-semibold text-uppercase tracking-wider small d-inline-flex align-items-center gap-1" style="color:var(--brt-gold)">
                <span class="material-symbols-outlined fs-6 anim-float-icon">eco</span> OUR PRODUCTS
            </span>
            <h2 class="fw-bold mt-2" style="color:var(--brt-green)">Premium Wholesale Selection</h2>
            <p class="text-muted mx-auto" style="max-width:600px">Top-tier mandi produce direct to distributors, hotels, and bulk retailers.</p>
        </div>
        <div class="row g-4">
            @foreach (var p in featured)
            {
                <div class="col-lg-4 col-md-6 fade-in-up">
                    <div class="innovative-card h-100 p-3 d-flex flex-column justify-content-between">
                        <div>
                            <div class="img-zoom-container bg-light text-center py-4 px-3 position-relative d-flex align-items-center justify-content-center" style="min-height: 220px; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" class="img-fluid object-fit-contain" style="max-height: 180px;" />
                                }
                                else
                                {
                                    <div class="rounded-circle p-4 bg-white shadow-sm text-green anim-float-icon">
                                        <span class="material-symbols-outlined display-4">
                                            @(p.SubCategory?.Category?.Type == BRT.Models.CategoryType.Garlic ? "eco" : "shopping_cart_checkout")
                                        </span>
                                    </div>
                                }
                                <span class="badge position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow-sm" style="background: var(--brt-green); color: #fff; font-size: 0.75rem;">
                                    @(p.SubCategory?.Name ?? "General")
                                </span>
                            </div>

                            <div class="pt-3 px-2">
                                <h4 class="card-title h5 fw-bold mb-1 text-dark">
                                    <span>@p.Name</span>
                                </h4>
                                @if (!string.IsNullOrEmpty(p.NameTamil))
                                {
                                    <span class="d-block text-muted small fw-medium mb-2">@p.NameTamil</span>
                                }
                                <p class="card-text text-muted small lh-base">
                                    @(string.IsNullOrEmpty(p.Description) ? "Standard commercial bulk packaging available with fresh mandi stock." : p.Description)
                                </p>
                            </div>
                        </div>

                        <div class="pt-3 px-2 mt-3 border-top d-flex justify-content-between align-items-center">
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2-5 py-1 rounded-pill extra-small fw-semibold">
                                Fresh Stock
                            </span>
                            <a asp-controller="Catalog" asp-action="Product" asp-route-slug="@p.Slug" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-semibold d-inline-flex align-items-center gap-1">
                                Details <span class="material-symbols-outlined fs-6 arrow-icon">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5 fade-in-up">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-brt-gold px-4 py-2-5 shadow-sm fw-semibold rounded-pill">View Full Catalog</a>
        </div>
    </section>
}

<!-- ===== Live Market Dashboard ===== -->
@{
    var dashboard = ViewBag.MarketDashboard as List<BRT.Models.MarketPrice>;
}
<section class="container my-5 py-4">
