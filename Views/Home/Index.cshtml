<!-- ===== Premium Hero ===== -->
<section class="hero-modern">
    <div class="hero-inner container">
        <div class="hero-content fade-in-up is-visible">
            <span class="hero-trust-badge"><span class="material-symbols-outlined">workspace_premium</span> Trusted Since 2000</span>
            <h1>B RAJ TRADERS</h1>
            <p class="hero-tagline">Garlic &amp; Grocery Commission Mandi<br class="d-none d-md-block" /> Trusted Dealer-to-Dealer Wholesale Supplier</p>

