<!-- ===== Inline CSS for Animations & Innovative Cards ===== -->
<style>
    :root {
        --brt-green: #1b3b22;
        --brt-green-light: #2d5a36;
        --brt-gold: #d4af37;
        --brt-gold-glow: rgba(212, 175, 55, 0.3);
    }

    /* Keyframe Animations Escaped for Razor (@@) */
    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
    }

    @@keyframes pulseGlow {
        0% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(212, 175, 55, 0); }
        100% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0); }
    }

    @@keyframes shineSweep {
        0% { left: -100%; }
        100% { left: 200%; }
    }

    /* Card Base Styles */
    .innovative-card {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .innovative-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
        transition: 0.5s;
        z-index: 2;
        pointer-events: none;
    }

    .innovative-card:hover::before {
        left: 200%;
    }

    .innovative-card:hover {
        transform: translateY(-8px) scale(1.01);
        border-color: var(--brt-gold) !important;
        box-shadow: 0 20px 40px rgba(27, 59, 34, 0.12), 0 0 15px var(--brt-gold-glow) !important;
    }

    /* Floating Icon Animation */
    .anim-float-icon {
        animation: floatIcon 3s ease-in-out infinite;
        display: inline-block;
    }

    /* Pulse Badge Animation */
    .pulse-badge {
        animation: pulseGlow 2s infinite;
    }

    /* Portfolio Hero Grid Cards */
    .portfolio-card-hero {
        border-radius: 24px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .portfolio-card-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(212, 175, 55, 0.15), transparent 70%);
        z-index: 0;
    }

    .portfolio-card-hero:hover {
        transform: translateY(-10px);
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
    }

    .portfolio-card-hero:hover .arrow-icon {
        transform: translateX(8px);
    }

    .arrow-icon {
        transition: transform 0.3s ease;
    }

    /* Image Container Zoom */
    .img-zoom-container {
        overflow: hidden;
        border-radius: 16px;
    }

    .img-zoom-container img {
        transition: transform 0.5s ease;
    }

    .innovative-card:hover .img-zoom-container img {
        transform: scale(1.1);
    }

    /* Utility Helpers */
    .extra-small { font-size: 0.78rem; }
    .bg-glass {
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
</style>

