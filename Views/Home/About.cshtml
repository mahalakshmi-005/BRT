@{
    ViewData["Title"] = "About Us";
}

<!-- Fonts & Material Icons CDN (Ensure these are in your Shared Layout) -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Cinzel:wght@600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --brt-gold: #D4AF37;
        --brt-gold-dark: #AA820A;
        --brt-green: #10B981;
        --dark-bg: #0F172A;
        --slate-cool: #F8FAFC;
        --border-color: #E2E8F0;
        --text-main: #1E293B;
        --text-muted: #64748B;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-main);
        background-color: #FAFAFA;
    }

    /* Innovative Sacred Symbol Wrapper */
    .sacred-band-wrapper {
        background: linear-gradient(180deg, rgba(212, 175, 55, 0.08) 0%, #FFFFFF 100%);
        padding: 24px 0 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-bottom: 1px solid rgba(212, 175, 55, 0.12);
    }

    .sacred-symbol-large {
        width: 42px;
        height: 42px;
        object-fit: contain;
        animation: pulseGlow 3s ease-in-out infinite;
    }

    .sacred-text-below {
        font-family: 'Cinzel', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--brt-gold-dark);
        letter-spacing: 3px;
        margin: 0;
        text-transform: uppercase;
    }

    @@keyframes pulseGlow {
        0% {
            transform: scale(1);
            filter: drop-shadow(0 2px 4px rgba(212, 175, 55, 0.2));
        }

        50% {
            transform: scale(1.06);
            filter: drop-shadow(0 4px 12px rgba(212, 175, 55, 0.4));
        }

        100% {
            transform: scale(1);
            filter: drop-shadow(0 2px 4px rgba(212, 175, 55, 0.2));
        }
    }

    /* Enhanced About Hero Layout */
    .about-hero {
        padding: 50px 0 40px;
        background: radial-gradient(circle at center, rgba(212, 175, 55, 0.06) 0%, transparent 70%);
        position: relative;
    }

    .about-logo-badge-giant {
        max-width: 220px;
        width: 100%;
        border-radius: 28px;
        box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.18);
        border: 5px solid #FFFFFF;
        margin-bottom: 2rem;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

        .about-logo-badge-giant:hover {
            transform: scale(1.06) translateY(-4px);
            box-shadow: 0 35px 60px -10px rgba(212, 175, 55, 0.25);
        }

    .about-hero-tagline {
        font-weight: 800;
        font-size: 2.8rem;
        letter-spacing: -1px;
        color: var(--dark-bg);
        margin-bottom: 0.5rem;
    }

    /* High-End Monochromatic Luxury Typographic Ribbon */
    .luxury-motto-ribbon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin: 1.2rem auto;
        padding: 14px 36px;
        background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 100px;
        box-shadow: 0 15px 35px rgba(15, 23, 42, 0.04);
        flex-wrap: wrap;
    }

    .luxury-motto-text {
        font-family: 'Cinzel', serif;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: #1E293B; /* Monochromatic Rich Slate Dark Tone */
        text-transform: uppercase;
        text-shadow: 0 1px 2px rgba(0,0,0,0.05);
        transition: color 0.3s ease;
    }

    .luxury-motto-ribbon:hover .luxury-motto-text {
        color: #0F172A; /* Refined focus shift */
    }

    .luxury-motto-divider {
        color: var(--brt-gold);
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* Asymmetric Section Intro */
    .hero-eyebrow {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-transform: uppercase;
    }

        .hero-eyebrow span {
            font-size: 1.2rem;
        }

    .section-title-premium {
        font-weight: 800;
        font-size: 2.5rem;
        color: var(--dark-bg);
        letter-spacing: -0.5px;
    }

    /* Interactive Stat Stack Layout */
    .stat-card-stack {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .stat-premium-box {
        background: #FFFFFF;
        border-radius: 20px;
        padding: 1.8rem;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

        .stat-premium-box:hover {
            transform: translateX(-8px);
            border-color: var(--brt-gold);
            box-shadow: 0 12px 24px rgba(212, 175, 55, 0.1);
        }

        .stat-premium-box .stat-num {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-bg);
            background: linear-gradient(135deg, var(--dark-bg) 0%, var(--brt-gold-dark) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-premium-box .stat-label {
            font-weight: 600;
            color: var(--text-muted);
            text-align: right;
            font-size: 1rem;
        }

    /* Modern Chronological Timeline Track */
    .modern-timeline {
        position: relative;
        padding: 2rem 0;
    }

        .modern-timeline::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, rgba(212, 175, 55, 0.1) 0%, var(--brt-gold) 50%, rgba(15, 23, 42, 0.1) 100%);
            transform: translateY(-50%);
            z-index: 1;
        }

    .timeline-node-premium {
        background: #FFFFFF;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 1.5rem 1rem;
        text-align: center;
        position: relative;
        z-index: 2;
        box-shadow: 0 10px 20px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

        .timeline-node-premium:hover {
            transform: translateY(-6px);
            border-color: var(--dark-bg);
            box-shadow: 0 15px 30px rgba(15, 23, 42, 0.08);
        }

    .node-year {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--brt-gold-dark);
        margin-bottom: 4px;
    }

    .node-dot {
        width: 12px;
        height: 12px;
        background: var(--dark-bg);
        border-radius: 50%;
        margin: 8px auto;
        border: 2px solid #FFFFFF;
        box-shadow: 0 0 0 4px rgba(15,23,42,0.1);
    }

    .node-desc {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-main);
    }

    /* Mission/Vision Split Cards */
    .mv-container-premium .mv-card-new {
        background: #FFFFFF;
        border-radius: 24px;
        padding: 3rem 2.5rem;
        border: 1px solid var(--border-color);
        min-height: 220px;
        height: 100%;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .mv-container-premium .mv-card-new::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--brt-gold);
            transition: width 0.3s ease;
            z-index: 1;
        }

        .mv-container-premium .mv-card-new:hover::after {
            width: 8px;
        }

    .mv-card-new span {
        font-size: 2.5rem;
        color: var(--dark-bg);
        margin-bottom: 1.5rem;
        display: inline-block;
    }

    .mv-card-new h4 {
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--dark-bg);
    }

    .mv-card-new p {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.6;
        margin: 0;
    }

    /* Fixed Layout for Trust Rows */
    .trust-box-premium {
        background: #FFFFFF;
        padding: 2.2rem;
        border-radius: 24px;
        border: 1px solid var(--border-color);
        display: flex;
        gap: 1.5rem;
        min-height: 150px;
        height: 100%;
        transition: all 0.35s ease;
    }

        .trust-box-premium:hover {
            box-shadow: 0 20px 35px rgba(15, 23, 42, 0.05);
            transform: translateY(-5px);
            border-color: rgba(212, 175, 55, 0.4);
        }

    .trust-icon-wrapper {
        width: 58px;
        height: 58px;
        background: rgba(212, 175, 55, 0.08);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .trust-box-premium:hover .trust-icon-wrapper {
        background: var(--dark-bg);
    }

        .trust-box-premium:hover .trust-icon-wrapper span {
            color: #FFFFFF;
        }

    .trust-icon-wrapper span {
        font-size: 1.8rem;
        color: var(--brt-gold-dark);
    }

    .trust-box-premium h5 {
        font-weight: 700;
        color: var(--dark-bg);
        margin-bottom: 0.6rem;
    }

    .trust-box-premium p {
        font-size: 0.94rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
    }

    /* Innovative Supply Chain Grading Cards */
    .process-card {
        background: #FFFFFF;
        border: 1px solid var(--border-color);
        border-radius: 24px;
        padding: 2rem;
        height: 100%;
        position: relative;
        transition: all 0.3s ease;
    }

        .process-card:hover {
            border-color: var(--brt-gold);
            box-shadow: 0 15px 30px rgba(212, 175, 55, 0.08);
            transform: translateY(-4px);
        }

    .process-badge {
        position: absolute;
        top: -15px;
        left: 25px;
        background: var(--dark-bg);
        color: #FFFFFF;
        font-weight: 800;
        padding: 4px 14px;
        border-radius: 50px;
        font-size: 0.8rem;
        border: 2px solid #FFFFFF;
    }

    .process-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--dark-bg);
        margin: 0.8rem 0 0.5rem 0;
    }

    .process-card p {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
    }

    /* Buttons Configuration */
    .btn-brt-gold {
        background: linear-gradient(135deg, var(--brt-gold) 0%, var(--brt-gold-dark) 100%);
        color: #FFFFFF !important;
        font-weight: 700;
        padding: 14px 36px;
        border-radius: 50px;
        border: none;
        box-shadow: 0 10px 20px rgba(212, 175, 55, 0.2);
        transition: all 0.3s ease;
    }

        .btn-brt-gold:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px rgba(212, 175, 55, 0.35);
        }

    .btn-brt-outline-dark {
        background: transparent;
        color: var(--dark-bg) !important;
        font-weight: 700;
        padding: 14px 36px;
        border-radius: 50px;
        border: 2px solid var(--dark-bg);
        transition: all 0.3s ease;
    }

        .btn-brt-outline-dark:hover {
            background: var(--dark-bg);
            color: #FFFFFF !important;
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .modern-timeline::before {
            display: none;
        }

        .modern-timeline .row {
            gap: 1rem;
        }

        .stat-premium-box:hover {
            transform: none;
        }

        .trust-box-premium {
            min-height: auto;
        }

        .luxury-motto-ribbon {
            flex-direction: column;
            gap: 12px;
            border-radius: 24px;
            padding: 20px 24px;
            width: 90%;
        }

        .luxury-motto-divider {
            display: none;
        }

        .luxury-motto-text {
            font-size: 1.15rem;
            letter-spacing: 1px;
        }
    }
</style>

<!-- ===== Sacred Symbol Header Band ===== -->
<div class="sacred-band-wrapper fade-in-up">
    <img src="/images/om-symbol.png" alt="Om Symbol" class="sacred-symbol-large" />
    <h1 class="sacred-text-below">ॐ Om Shanthi ॐ</h1>
</div>

<!-- ===== Re-Engineered Hero Layout (Mandi Text Removed & Monochromatic Gold Layout Applied) ===== -->
<section class="page-hero about-hero text-center">
    <div class="container">
        <img src="/images/brt-logo.jpeg" alt="B Raj Traders Logo" class="about-logo-badge giant about-logo-badge-giant fade-in-up" />
        <h2 class="about-hero-tagline fade-in-up">B Raj Traders</h2>

        <!-- Elegant Monochromatic Structural Layout Block -->
        <div class="luxury-motto-ribbon fade-in-up">
            <span class="luxury-motto-text">Honest Pricing</span>
            <span class="luxury-motto-divider">♦</span>
            <span class="luxury-motto-text">Premium Quality</span>
            <span class="luxury-motto-divider">♦</span>
            <span class="luxury-motto-text">Unmatched Legacy</span>
        </div>
    </div>
</section>

<div class="container my-5">

    <!-- ===== Our Story ===== -->
    <div class="row g-5 align-items-center info-section mb-5">
        <div class="col-lg-7 col-md-12 fade-left">
            <span class="hero-eyebrow" style="color:var(--brt-gold)"><span class="material-symbols-outlined">history_edu</span> OUR STORY</span>
            <h3 class="section-title-premium mt-2 mb-4">A Legacy Built on Trust</h3>
            <p class="fs-6 text-secondary mb-3">
                For over 25 years, B Raj Traders has been a trusted name in the garlic and grocery industry.
                Established in 2000 in Theni District, Tamil Nadu, we have built our reputation by delivering
                quality products, honest pricing, and dependable service.
            </p>
            <p class="fs-6 text-secondary mb-3">
                We work closely with farmers, suppliers, wholesalers, retailers, and distributors to ensure
                every product meets the highest standards of freshness and quality. Our focus is not just on
                selling products but on helping our business partners grow with a reliable and uninterrupted
                supply.
            </p>
            <p class="fs-6 text-secondary mb-4">
                With years of market experience and a customer-first approach, we understand the needs of
                dealers and businesses. Every order is handled with care, transparency, and a commitment to
                timely delivery.
            </p>
            <div class="p-3 border-start border-3 border-success bg-light rounded-end">
                <span class="fw-bold d-block" style="color:var(--brt-green)">
                    B Raj Traders — Your Trusted Partner in Garlic &amp; Grocery Since 2000.
                </span>
            </div>
        </div>
        <div class="col-lg-5 col-md-12 fade-right mt-4 mt-lg-0">
            <div class="stat-card-stack">
                <div class="stat-premium-box">
                    <div class="stat-num">25+</div>
                    <div class="stat-label">Years of Elite<br><small class="text-muted">Market Experience</small></div>
                </div>
                <div class="stat-premium-box">
                    <div class="stat-num">1000+</div>
                    <div class="stat-label">B2B Dealers<br><small class="text-muted">Actively Served</small></div>
                </div>
                <div class="stat-premium-box">
                    <div class="stat-num">30+</div>
                    <div class="stat-label">Premium Products<br><small class="text-muted">Always In Stock</small></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Journey Timeline ===== -->
    <div class="modern-timeline my-5 pt-4 pb-5">
        <div class="row g-3 justify-content-center">
            <div class="col-lg-3 col-md-6">
                <div class="timeline-node-premium">
                    <div class="node-year">2000</div>
                    <div class="node-dot"></div>
                    <div class="node-desc">Inception in Theni Mandi</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="timeline-node-premium">
                    <div class="node-year">2012</div>
                    <div class="node-dot"></div>
                    <div class="node-desc">Expanded Dealer Network</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="timeline-node-premium">
                    <div class="node-year">2018</div>
                    <div class="node-dot"></div>
                    <div class="node-desc">Full Wholesale Integration</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="timeline-node-premium">
                    <div class="node-year">Today</div>
                    <div class="node-dot"></div>
                    <div class="node-desc">Pan-India Trusted Supply</div>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25" />

    <!-- ===== Mission / Vision ===== -->
    <div class="row g-4 info-section mv-container-premium my-5">
        <div class="col-md-6 fade-in-up">
            <div class="mv-card-new">
                <span class="material-symbols-outlined">flag</span>
                <h4>Our Mission</h4>
                <p>To provide fresh, high-quality garlic and grocery products with integrity, consistency, and exceptional customer service.</p>
            </div>
        </div>
        <div class="col-md-6 fade-in-up">
            <div class="mv-card-new">
                <span class="material-symbols-outlined">visibility</span>
                <h4>Our Vision</h4>
                <p>To become a leading and trusted supplier of premium garlic and grocery products in both domestic and international markets.</p>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25" />

    <!-- ===== Why Trust Us ===== -->
    <div class="text-center mb-5 fade-in-up">
        <span class="hero-eyebrow" style="color:var(--brt-gold)"><span class="material-symbols-outlined">verified_user</span> WHY DEALERS TRUST US</span>
        <h3 class="fw-bold mt-2">Core Commitments To The Trade</h3>
    </div>

    <div class="row g-4 info-section mb-5">
        <div class="col-md-6">
            <div class="trust-box-premium fade-left">
                <div class="trust-icon-wrapper"><span class="material-symbols-outlined">eco</span></div>
                <div>
                    <h5>Consistent Product Quality</h5>
                    <p>Every batch of garlic is graded and sorted — Bomb, Laddu, AAA, Bold and more — so you always know the quality you're buying.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="trust-box-premium fade-right">
                <div class="trust-icon-wrapper"><span class="material-symbols-outlined">verified</span></div>
                <div>
                    <h5>Transparent &amp; Trustworthy</h5>
                    <p>Today's market rate, previous rate, and the difference are shown for every product — no guessing, no hidden margins.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="trust-box-premium fade-left">
                <div class="trust-icon-wrapper"><span class="material-symbols-outlined">local_shipping</span></div>
                <div>
                    <h5>On-Time Dispatch &amp; Delivery</h5>
                    <p>We work exclusively in bulk B2B trade — no retail shortcuts — so our terms are built around dealer volumes and reliable dispatch schedules.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="trust-box-premium fade-right">
                <div class="trust-icon-wrapper"><span class="material-symbols-outlined">support_agent</span></div>
                <div>
                    <h5>Dedicated Dealer Support</h5>
                    <p>Direct WhatsApp updates, confirmations, and dispatch details for our dealer network — no call centres, no middlemen.</p>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25" />

    <!-- ===== INNOVATIVE MANDI WORKFLOW TRACK ===== -->
    <div class="text-center mb-5 fade-in-up">
        <span class="hero-eyebrow" style="color:var(--brt-gold)"><span class="material-symbols-outlined">published_with_changes</span> MANDI WORKFLOW</span>
        <h3 class="fw-bold mt-2">Our Premium Sourcing &amp; Grading Standards</h3>
    </div>

    <div class="row g-4 justify-content-center mb-5">
        <div class="col-md-4 col-sm-6">
            <div class="process-card">
                <div class="process-badge">01</div>
                <span class="material-symbols-outlined text-success fs-2 mt-2">agriculture</span>
                <h4>Direct Farm Sourcing</h4>
                <p>Procured directly from handpicked mountain fields &amp; top farmers ensuring maximum natural essence and long shelf life.</p>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="process-card">
                <div class="process-badge" style="background:var(--brt-gold-dark)">02</div>
                <span class="material-symbols-outlined text-warning fs-2 mt-2">layers</span>
                <h4>Rigorous Size Grading</h4>
                <p>Strict structural sizing into clear commercial sets: Bomb, Laddu, AAA, and medium grades for absolute marketplace predictability.</p>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="process-card">
                <div class="process-badge" style="background: #E11D48;">03</div>
                <span class="material-symbols-outlined text-danger fs-2 mt-2">local_shipping</span>
                <h4>Seamless B2B Delivery</h4>
                <p>Bulk moisture-controlled gunny bag packing followed by immediate dispatch across Tamil Nadu, Pondicherry, and Pan-India networks.</p>
            </div>
        </div>
    </div>

    <div class="text-center mt-5 pt-3 fade-in-up">
        <p class="text-muted mb-4 fw-medium">We supply across India, with direct dedicated supply to Pondicherry and 15+ districts in Tamil Nadu.</p>
        <a asp-controller="Order" asp-action="Request" class="btn btn-brt-gold mx-2 my-2 px-4 py-3 text-uppercase fs-7">Request Bulk Order</a>
        <a asp-controller="Contact" asp-action="Index" class="btn btn-brt-outline-dark mx-2 my-2 px-4 py-3 text-uppercase fs-7">Contact Us</a>
    </div>
</div>